<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>互联网奇观 · 人物档案馆</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700;900&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════
   互联网奇观 · 人物档案馆 —  Index
   Museum-grade archival presentation
   ═══════════════════════════════════════════════════════ */

*{margin:0;padding:0;box-sizing:border-box}

/* ── Museum Hall ── */
body{
  background:#171412;
  font-family:'Noto Serif SC','ZCOOL XiaoWei','Source Han Serif SC','FangSong','STFangsong','STSong','Times New Roman',Georgia,serif;
  color:#d0c4b4;line-height:1.8;min-height:100vh;
  -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale
}

/* Multi-layer: wood grain + noise + vignette + spotlight */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:9995;
  background:
    repeating-linear-gradient(87deg,transparent,transparent 40px,rgba(40,30,20,0.008) 40px,rgba(40,30,20,0.008) 41px),
    repeating-linear-gradient(3deg,transparent,transparent 50px,rgba(35,28,22,0.005) 50px,rgba(35,28,22,0.005) 51px)
}
body::after{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:9996;
  background:radial-gradient(ellipse 70% 60% at 50% 30%,rgba(160,120,60,0.015) 0%,transparent 60%),
    radial-gradient(ellipse 120% 100% at 50% 100%,rgba(0,0,0,0.4) 0%,transparent 60%)
}
body z{content:'';position:fixed;inset:0;pointer-events:none;z-index:9997;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 500 500' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='6' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  background-size:500px 500px
}

/* ── Parchment Container ── */
.wrap{
  max-width:1100px;margin:48px auto;position:relative;z-index:2;
  background:linear-gradient(175deg,rgba(22,18,14,0.75) 0%,rgba(16,13,10,0.8) 100%);
  box-shadow:
    0 0 0 1px rgba(80,65,50,0.15),
    0 0 0 2px rgba(12,10,8,0.6),
    0 4px 60px rgba(0,0,0,0.5),
    inset 0 0 60px rgba(0,0,0,0.15);
  padding:0 0 1px 0
}

/* ── Hero ── */
.hero{
  padding:80px 30px 50px;text-align:center;position:relative;
  border-bottom:1px solid rgba(60,45,35,0.5)
}
.hero::after{
  content:'';position:absolute;bottom:-1px;left:32px;right:32px;height:1px;
  background:linear-gradient(90deg,transparent,rgba(160,130,100,0.15) 10%,rgba(160,130,100,0.1) 50%,rgba(160,130,100,0.15) 90%,transparent)
}
.hero::before{
  content:'';position:absolute;top:-50%;left:0;right:0;height:250%;
  background:radial-gradient(ellipse 60% 30% at 50% 40%,rgba(160,120,60,0.025) 0%,transparent 70%);pointer-events:none
}
.hero h1{
  font-size:52px;font-weight:400;color:#e4d8c8;letter-spacing:20px;line-height:1.2;
  text-shadow:0 2px 8px rgba(0,0,0,0.3),0 0 60px rgba(160,120,60,0.035);
  font-family:'Noto Serif SC','ZCOOL XiaoWei','Times New Roman',serif;font-weight:900
}
.hero .sub{
  font-size:11px;color:#7a6a5a;margin-top:14px;letter-spacing:10px;font-weight:300;
  position:relative;display:inline-block
}
.hero .sub::before,.hero .sub::after{
  content:'◆';font-size:5px;color:#5a4a3a;margin:0 14px;vertical-align:middle;opacity:.5
}
.hero .desc{
  font-size:11px;color:#8a7a6a;max-width:500px;margin:24px auto 0;line-height:2.4;font-weight:300
}
.hero .desc::before{
  display:block;content:'❦';font-size:13px;color:rgba(60,45,35,0.3);margin-bottom:14px;font-family:Georgia,serif
}

/* ── Entry List ── */
.entries{padding:36px 0}
.entry-head{
  font-size:8px;color:#6a5a4a;letter-spacing:7px;text-transform:uppercase;font-weight:300;
  margin:0 36px 28px;padding-bottom:12px;position:relative;font-family:'Times New Roman',Georgia,serif
}
.entry-head::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,rgba(100,80,60,0.5) 15%,rgba(100,80,60,0.1) 50%,transparent)
}

/* ── Entry Grid ── */
.entries-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:0 36px 24px}

/* ── Featured Cards ── */
.featured{display:block;padding:0;margin:0;
  transition:all .3s;text-decoration:none;color:inherit;position:relative;
  background:rgba(18,15,13,0.3);
  border:1px solid rgba(60,45,35,0.35);
  box-shadow:0 1px 4px rgba(0,0,0,0.15);
  overflow:hidden
}
.featured:hover{
  background:rgba(26,22,18,0.4);
  border-color:rgba(80,65,50,0.5);
  box-shadow:0 4px 20px rgba(0,0,0,0.35),0 1px 4px rgba(0,0,0,0.15);
  transform:translateY(-2px)
}
.featured:hover .fc-link{color:#c0a070}
.featured .fc-img{
  aspect-ratio:1/1;width:100%;object-fit:cover;object-position:center 30%;
  display:block;opacity:.75;transition:opacity .4s
}
.featured:hover .fc-img{opacity:1}
.featured .fc-body{padding:12px 14px 14px;display:flex;flex-direction:column;justify-content:center}
.featured .fc-tag{font-size:7px;color:#b8962e;letter-spacing:4px;text-transform:uppercase;font-weight:300}
.featured .fc-title{
  font-size:18px;font-weight:400;color:#e4d8c8;letter-spacing:8px;margin-top:4px;
  font-family:'Noto Serif SC','Source Han Serif SC',serif
}
.featured .fc-meta{font-size:9px;color:#7a6a5a;margin-top:4px;font-weight:300}
.featured .fc-meta .hl{color:#c0a070}
.featured .fc-stats{display:flex;gap:24px;margin-top:16px;flex-wrap:wrap}
.featured .fc-stats span{font-size:8px;color:#6a5a4a;font-weight:300;letter-spacing:.3px}
.featured .fc-stats b{
  color:#c0a070;font-size:13px;font-family:'Times New Roman',Georgia,serif;
  display:block;line-height:1;letter-spacing:1px
}
.featured .fc-link{
  display:inline-block;margin-top:16px;font-size:10px;color:#8a7a6a;
  text-decoration:none;letter-spacing:4px;transition:color .3s;font-weight:300;
  position:relative;padding-right:18px
}
.featured .fc-link::after{content:'→';position:absolute;right:0;transition:right .3s}
.featured .fc-link:hover::after{right:-4px}

/* ── Placeholder Grid ── */
.card-grid{
  display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;
  margin:0 24px;
  background:rgba(60,45,35,0.25);border:1px solid rgba(60,45,35,0.35)
}
.card-grid>a{
  background:rgba(18,15,13,0.3);padding:40px 20px;text-align:center;
  text-decoration:none;transition:all .3s;
  display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:160px
}
.card-grid>a:hover{background:rgba(26,22,18,0.4)}
.card-grid .ci{font-size:24px;margin-bottom:10px;opacity:.12;color:#8a7a6a}
.card-grid .cn{font-size:13px;color:#5a4a3a;letter-spacing:6px;font-weight:300}
.card-grid .cd{font-size:9px;color:#4a3a2a;margin-top:4px;letter-spacing:2px;font-weight:300}

/* ── Suggestion Wall ── */
.suggest-section{padding:36px 0 0}
.suggest-form{margin:0 36px 24px;padding:20px 24px;background:rgba(18,15,13,0.3);border:1px solid rgba(60,45,35,0.35);display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.suggest-form input{flex:1;min-width:160px;padding:8px 14px;background:rgba(30,25,20,0.6);border:1px solid rgba(80,65,50,0.4);color:#d0c4b4;font-family:inherit;font-size:14px;letter-spacing:2px;outline:none;transition:border-color .3s}
.suggest-form input:focus{border-color:rgba(160,130,100,0.5)}
.suggest-form input::placeholder{color:#5a4a3a;letter-spacing:4px;font-size:11px}
.suggest-form button{padding:8px 20px;background:rgba(80,65,50,0.3);border:1px solid rgba(80,65,50,0.5);color:#c0a070;font-family:inherit;font-size:11px;letter-spacing:6px;cursor:pointer;transition:all .3s}
.suggest-form button:hover{background:rgba(100,80,60,0.4);border-color:rgba(160,130,100,0.5)}
.suggest-form button:disabled{opacity:.3;cursor:not-allowed}
.suggest-msg{margin:0 36px;font-size:10px;letter-spacing:3px;min-height:20px}
.suggest-msg.ok{color:#7a9a6a}
.suggest-msg.err{color:#9a5a4a}
.suggest-list{margin:12px 36px 0;display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.suggest-item{padding:16px;background:rgba(18,15,13,0.3);border:1px solid rgba(60,45,35,0.35);font-size:15px;color:#c0b09a;letter-spacing:4px;text-align:center;cursor:default;transition:all .3s}
.suggest-item:hover{background:rgba(26,22,18,0.4);border-color:rgba(80,65,50,0.5);color:#e4d8c8}
.suggest-empty{font-size:10px;color:#5a4a3a;letter-spacing:4px;margin:0 36px;grid-column:1/-1;text-align:center;padding:20px 0}

/* ── Colophon ── */
.footer{
  padding:34px 30px 38px;text-align:center;font-size:8px;color:#4a3a2a;
  letter-spacing:3px;line-height:2.4;font-weight:300;
  border-top:1px solid rgba(60,45,35,0.4);position:relative
}
.footer::before{
  content:'';position:absolute;top:-1px;left:32px;right:32px;height:1px;
  background:linear-gradient(90deg,transparent,rgba(100,80,60,0.3) 10%,rgba(100,80,60,0.2) 50%,rgba(100,80,60,0.3) 90%,transparent)
}


/* ── Admin Panel ── */
.admin-overlay{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.7);backdrop-filter:blur(4px);overflow-y:auto}
.admin-overlay.open{display:block}
.admin-panel{max-width:900px;margin:60px auto;background:#1a1612;border:1px solid rgba(80,65,50,0.4);padding:32px 36px;position:relative}
.admin-panel h2{font-size:18px;font-weight:400;color:#c0a070;letter-spacing:8px;margin-bottom:24px;padding-bottom:12px;border-bottom:1px solid rgba(80,65,50,0.3)}
.admin-close{position:absolute;top:16px;right:20px;color:#6a5a4a;font-size:20px;cursor:pointer;border:none;background:none;font-family:inherit}
.admin-close:hover{color:#c0a070}
.admin-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.admin-card{background:rgba(30,25,20,0.4);border:1px solid rgba(60,45,35,0.3);padding:16px;text-align:center}
.admin-card .ac-title{font-size:14px;color:#d0c4b4;letter-spacing:4px;margin-bottom:8px}
.admin-card .ac-preview{width:100%;aspect-ratio:1/1;object-fit:cover;display:block;margin-bottom:8px;background:rgba(40,32,26,0.3)}
.admin-card .ac-placeholder{width:100%;aspect-ratio:1/1;display:flex;align-items:center;justify-content:center;background:rgba(40,32,26,0.3);margin-bottom:8px;color:#5a4a3a;font-size:10px;letter-spacing:3px}
.admin-card .ac-status{font-size:9px;margin-bottom:8px;letter-spacing:2px}
.admin-card .ac-status.ok{color:#7a9a6a}
.admin-card .ac-status.missing{color:#9a5a4a}
.admin-card .ac-upload{font-size:9px;color:#8a7a6a;cursor:pointer;letter-spacing:3px;padding:6px 12px;border:1px solid rgba(80,65,50,0.3);background:rgba(40,32,26,0.3);transition:all .3s;font-family:inherit}
.admin-card .ac-upload:hover{background:rgba(60,45,35,0.4);color:#c0a070}
.admin-card .ac-upload input{display:none}

/* ── Responsive ── */
@media(max-width:640px){
  body::before,body::after,body z{display:none}
  .wrap{margin:10px 6px}
  .hero{padding:48px 16px 36px}
  .hero h1{font-size:32px;letter-spacing:12px}
  .hero .sub::before,.hero .sub::after{display:none}
  .hero .sub{letter-spacing:6px}
  .featured{margin:0}
  .entries-grid{grid-template-columns:repeat(2,1fr);gap:10px;margin:0 10px}
  .featured .fc-img{aspect-ratio:1/1;width:100%}
  .featured .fc-body{padding:18px 20px}
  .featured .fc-title{font-size:22px;letter-spacing:8px}
  .card-grid{grid-template-columns:1fr;margin:0 10px}
  .card-grid>a{min-height:120px;padding:25px}
  .entry-head{margin-left:18px;margin-right:18px}
  .footer{padding:24px 16px 28px}
  .suggest-form{margin:0 16px 18px;padding:14px 16px}
  .suggest-list{margin:12px 16px 0;grid-template-columns:repeat(2,1fr)}
  .suggest-empty{margin:0 16px}
  .suggest-msg{margin:0 16px}
}
</style>
</head>
