<script>
(async function(){
  try{
    let r=await fetch('/api/count',{method:'POST'});
    let d=await r.json();
    document.getElementById('vcounter').textContent='◈ 访客 ' + d.count + ' ◈';
  }catch(e){
    document.getElementById('vcounter').textContent='◈ 访客 − ◈';
  }
})();

async function loadSuggestions(){
  const el=document.getElementById('suggestList');
  try{
    const r=await fetch('/api/suggestions');
    const d=await r.json();
    if(!d.suggestions||d.suggestions.length===0){
      el.innerHTML='<div class="suggest-empty">还没有建议，来写第一个吧</div>';
      return;
    }
    el.innerHTML=d.suggestions.map(s=>
      '<span class="suggest-item">'+s.name.replace(/</g,'&lt;')+'</span>'
    ).join('');
  }catch(e){
    el.innerHTML='<div class="suggest-empty">加载失败</div>';
  }
}

async function submitSuggestion(){
  const input=document.getElementById('suggestInput');
  const btn=document.getElementById('suggestBtn');
  const msg=document.getElementById('suggestMsg');
  const name=input.value.trim();
  if(!name){msg.className='suggest-msg err';msg.textContent='输入不能为空';return}
  btn.disabled=true;btn.textContent='提交中';
  msg.className='suggest-msg';
  msg.textContent='';
  try{
    const r=await fetch('/api/suggest',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name})});
    const d=await r.json();
    if(r.ok){
      msg.className='suggest-msg ok';
      msg.textContent='已收到，谢谢建议 🦞';
      input.value='';
      loadSuggestions();
    }else{
      msg.className='suggest-msg err';
      msg.textContent=d.error||'提交失败';
    }
  }catch(e){
    msg.className='suggest-msg err';
    msg.textContent='网络错误，请重试';
  }
  btn.disabled=false;btn.textContent='提交';
}

loadSuggestions();

document.getElementById('suggestInput').addEventListener('keydown',function(e){if(e.key==='Enter')submitSuggestion()});

/* ── Admin ── */
let adminClickCount = 0;
let adminClickTimer = null;

document.querySelector('.footer').addEventListener('click', function(e) {
  if (e.target.tagName === 'SPAN' || e.target.closest('.footer')) {
    adminClickCount++;
    clearTimeout(adminClickTimer);
    adminClickTimer = setTimeout(() => { adminClickCount = 0; }, 2000);
    if (adminClickCount >= 5) {
      adminClickCount = 0;
      openAdmin();
    }
  }
});

async function openAdmin() {
  document.getElementById('adminOverlay').classList.add('open');
  await loadAdminPanel();
}

function closeAdmin() {
  document.getElementById('adminOverlay').classList.remove('open');
}

async function loadAdminPanel() {
  const grid = document.getElementById('adminGrid');
  grid.innerHTML = '验证中...';
  try {
    const authR = await fetch('/api/admin/verify', { method: 'POST', headers: { 'X-Admin-Token': 'xiaolongxia2024' } });
    const authD = await authR.json();
    if (!authD.ok) {
      grid.innerHTML = '<div style="color:#9a5a4a;grid-column:1/-1;text-align:center;padding:20px">验证失败</div>';
      return;
    }
    const r = await fetch('/api/admin/image-status', { headers: { 'X-Admin-Token': 'xiaolongxia2024' } });
    const d = await r.json();
    const slugs = Object.keys(d.status);
    grid.innerHTML = slugs.map(slug => {
      const info = d.status[slug];
      const hasImg = info.hasAvatar;
      const nameMap = { changshu_anuo:'常熟阿诺', laochen:'反诈老陈', mabaoguo:'马保国', xiucai:'秀才', dingzhen:'丁真', fanxiaoqin:'范小勤', fengge:'峰哥', liangzi:'良子', sanheshen:'三和大神', wangweiheng:'王伟恒', wujing:'吴京', zhangxuefeng:'张雪峰', laoa:'牢A' };
      return '<div class="admin-card">' +
        '<div class="ac-title">' + (nameMap[slug] || slug) + '</div>' +
        (hasImg
          ? '<img class="ac-preview" src="' + info.avatarUrl + '?t=' + Date.now() + '" alt="">'
          : '<div class="ac-placeholder">暂无图片</div>') +
        '<div class="ac-status ' + (hasImg ? 'ok' : 'missing') + '">' + (hasImg ? '✓ 已有头像' : '✗ 缺头像') + '</div>' +
        '<label class="ac-upload">上传图片<input type="file" accept="image/*" onchange="uploadImage('' + slug + '', this)"></label>' +
        '</div>';
    }).join('');
  } catch(e) {
    grid.innerHTML = '<div style="color:#9a5a4a;grid-column:1/-1;text-align:center;padding:20px">加载失败</div>';
  }
}

async function uploadImage(slug, input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = async function(e) {
    const dataUrl = e.target.result;
    try {
      const r = await fetch('/api/admin/upload-image', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Admin-Token': 'xiaolongxia2024' },
        body: JSON.stringify({ slug, image: dataUrl, type: 'avatar' })
      });
      const d = await r.json();
      if (d.ok) {
        input.value = '';
        loadAdminPanel();
        // Also reload the page's card images
        document.querySelectorAll('.featured .fc-img').forEach(img => {
          if (img.src.includes(slug)) img.src = d.url + '?t=' + Date.now();
        });
      } else {
        alert('上传失败: ' + (d.error || '未知错误'));
      }
    } catch(e) {
      alert('上传失败');
    }
  };
  reader.readAsDataURL(file);
}

// Allow opening admin via URL param
if (window.location.search.includes('admin=1')) {
  setTimeout(openAdmin, 500);
}

