---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { getAvatar, getHero } from '../utils/imageResolver';

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect('/404');
}

const entry = await getEntry('phenomenon', slug);
if (!entry) {
  return Astro.redirect('/404');
}

const data = entry.data;

let essayHtml = data.essay || '';
let commentHtml = data.comment || '';
const glossary = data.glossary || [];

if (glossary.length > 0) {
  glossary.forEach(item => {
    const escapedKey = item.key.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&');
    const regex = new RegExp(`(?<!<[^>]*)(${escapedKey})(?![^<]*>)`, 'g');
    const replacement = `<span class="glossary-term" data-tip="${item.val.replace(/"/g, '&quot;')}">$1</span>`;
    
    if (essayHtml) {
      essayHtml = essayHtml.replace(regex, replacement);
    }
    if (commentHtml) {
      commentHtml = commentHtml.replace(regex, replacement);
    }
  });
}

const entryAvatar = getAvatar(slug, data.avatar);
const entryHero = getHero(slug, data.hero);

const hasHero = !!entryHero;
const isSvgPlaceholder = hasHero && entryHero.endsWith('.svg');

const scores = data.scores || {
  popularity: 5,
  dispute: 5,
  absurdity: 5,
  slice: 5,
  narrative: 5,
  native: 5,
};
---
<Layout title={`${data.title} · 互联网奇观 · 人物档案馆`}>
  <a class="back-link" href="/">← 返回档案目录</a>
  <div class="wrap">
    <!-- 盖章降临组件 -->
    <div class={`impact-stamp stamp-level-${data.clearance || 'D'}`} id="impactStamp">
      <span class="stamp-title">DECLASSIFIED</span>
      <span class="stamp-level">{data.clearance || 'D'}级解密</span>
      <span class="stamp-date">No. ODD-{slug.substring(0, 3).toUpperCase()}</span>
    </div>
    <div class="hero">
      {hasHero && (
        isSvgPlaceholder ? (
          <>
            <div class="hero-pattern-sm" />
            <div class="hero-overlay" />
            {entryAvatar && !entryAvatar.endsWith('.svg') && !entryAvatar.endsWith('placeholder-avatar.svg') ? (
              <div class="hero-portrait">
                <Image 
                  src={entryAvatar} 
                  alt={data.title} 
                  width={200} 
                  height={200} 
                  format="webp" 
                  inferSize={true}
                  class="portrait-img"
                />
              </div>
            ) : (
              <div class="hero-portrait">
                <img class="portrait-svg" src={entryAvatar || entryHero} alt={data.title} />
              </div>
            )}
          </>
        ) : (
          <>
            <img class="hero-img is-photo" src={entryHero} alt={data.title} />
            <div class="hero-overlay" />
            {entryAvatar && !entryAvatar.endsWith('.svg') && !entryAvatar.endsWith('placeholder-avatar.svg') ? (
              <div class="hero-portrait">
                <Image 
                  src={entryAvatar} 
                  alt={data.title} 
                  width={200} 
                  height={200} 
                  format="webp" 
                  inferSize={true}
                  class="portrait-img"
                />
              </div>
            ) : (
              <div class="hero-portrait">
                <img class="portrait-svg" src={entryAvatar || entryHero} alt={data.title} />
              </div>
            )
          </>
        )
      )}
      {!hasHero && (
        <div class="hero-pattern">
          {data.hero_type === 'person' ? (
            <div style="inset:0;position:absolute;background:radial-gradient(ellipse 120% 60% at 20% 40%, rgba(120,60,40,0.04) 0%, transparent 60%),repeating-linear-gradient(45deg,transparent,transparent 40px,rgba(200,160,120,0.008) 40px,rgba(200,160,120,0.008) 41px)" />
          ) : (
            <div class="hero-pattern-sm" />
          )}
        </div>
      )}
      <div class="hero-text">
        <div class="tag">档案 {data.hero_tag}</div>
        {data.hero_type && <div class="type">{data.hero_type}</div>}
        <h1 class="decrypt-text" data-text={data.title}>{data.title}</h1>
        <div class="sub" set:html={data.subtitle}></div>
      </div>
    </div>

    <div class="ribbon">
      {data.ribbon.map(r => (
        <div>
          <span class={`nu ${r.color || ''}`}>
            <Fragment set:html={r.num} />
            {r.note && <span class="sm" set:html={r.note} />}
          </span>
          <span class="lb" set:html={r.label} />
        </div>
      ))}
    </div>

    <div class="main-stat">
      <div>
        <div class="mn" set:html={data.main_stat.big_number}></div>
        <div class="mu" set:html={data.main_stat.big_unit}></div>
        {data.main_stat.big_desc && <div class="desc-sm" style="margin-top:4px" set:html={data.main_stat.big_desc}></div>}
        {data.main_stat.big_sublabel && <div class="subl" set:html={data.main_stat.big_sublabel}></div>}
      </div>
      <div>
        <div class="md">
          {data.main_stat.bio.map(line => (
            <Fragment set:html={line} /><br />
          ))}
        </div>
      </div>
    </div>

    <div class="data-grid">
      {data.data_grid.map(dg => (
        <div>
          <div class="gl">{dg.label}</div>
          <div class={`gv ${dg.color || ''}`}>
            <Fragment set:html={dg.value} />
            {dg.unit && (
              <span class="sm">
                {String(dg.value) !== '8+' && 
                 String(dg.value) !== '30+' && 
                 String(dg.value) !== '10/10' && 
                 String(dg.value) !== '二级' && 
                 String(dg.value) !== '<1000' && 
                 dg.unit}
              </span>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- ── 奇观综合评分评估板 ── -->
    <div class="evaluation-section">
      <div class="st">▎奇观综合指数评估</div>
      <div class="eval-grid">
        <div class="radar-container">
          <svg id="radar-chart" width="220" height="220" viewBox="0 0 220 220" style="overflow:visible">
            <!-- 动态渲染 SVG 雷达图 -->
          </svg>
        </div>
        <div class="eval-scores">
          <div class="score-item" data-index="0" data-val={scores.popularity}>
            <span class="sn">国民度</span>
            <div class="sb-wrap">
              <div class="sb-bar"></div>
            </div>
            <span class="sv">{scores.popularity}</span>
          </div>
          <div class="score-item" data-index="1" data-val={scores.dispute}>
            <span class="sn">争议性</span>
            <div class="sb-wrap">
              <div class="sb-bar"></div>
            </div>
            <span class="sv">{scores.dispute}</span>
          </div>
          <div class="score-item" data-index="2" data-val={scores.absurdity}>
            <span class="sn">荒诞性</span>
            <div class="sb-wrap">
              <div class="sb-bar"></div>
            </div>
            <span class="sv">{scores.absurdity}</span>
          </div>
          <div class="score-item" data-index="3" data-val={scores.slice}>
            <span class="sn">时代切片性</span>
            <div class="sb-wrap">
              <div class="sb-bar"></div>
            </div>
            <span class="sv">{scores.slice}</span>
          </div>
          <div class="score-item" data-index="4" data-val={scores.narrative}>
            <span class="sn">叙事弧光</span>
            <div class="sb-wrap">
              <div class="sb-bar"></div>
            </div>
            <span class="sv">{scores.narrative}</span>
          </div>
          <div class="score-item" data-index="5" data-val={scores.native}>
            <span class="sn">互联网原生性</span>
            <div class="sb-wrap">
              <div class="sb-bar"></div>
            </div>
            <span class="sv">{scores.native}</span>
          </div>
        </div>
      </div>
    </div>

    {data.body_grid && data.body_grid.length > 0 && (
      <div class="body-grid">
        {data.body_grid.map(bg => (
          <div>
            <div class="bl">{bg.label}</div>
            <div class="bv">
              <Fragment set:html={bg.value} />
              {bg.sub && <span class="bs">{bg.sub}</span>}
            </div>
          </div>
        ))}
      </div>
    )}

    {data.timeline && data.timeline.length > 0 && (
      <div class="section">
        <div class="st">▎生平纪事</div>
        <div class="tl-grid">
          {data.timeline.map(t => (
            <div class="tl-item">
              <span class="yr">{t.year}</span>
              <div class="td" set:html={t.text} />
            </div>
          ))}
        </div>
      </div>
    )}

    {data.quote && (
      <div class="section" style="padding:20px 34px">
        <div class="st">▎经典语录</div>
        <div class="pull-quote" style="border:none;padding:0">
          <div class="pq" set:html={data.quote.text}></div>
          <div class="ps" set:html={data.quote.source}></div>
        </div>
      </div>
    )}

    {data.num_strip && data.num_strip.length > 0 && (
      <div class="num-strip">
        {data.num_strip.map(ns => (
          <div class="ni">
            <div class="nu" set:html={ns.num}></div>
            <div class="nl" set:html={ns.label}></div>
          </div>
        ))}
      </div>
    )}

    {data.quote_list && data.quote_list.length > 0 && (
      <div class="section" style="padding:20px 34px">
        <div class="st">▎更多言论</div>
        <div class="qlist" style="border:none;padding:0">
          <div class="qs">
            {data.quote_list.map(q => (
              <Fragment set:html={q} /><br /><br />
            ))}
          </div>
        </div>
      </div>
    )}

    {data.video && (
      <div class="section" style="padding:20px 34px">
        <div class="st">▎相关视频</div>
        <div class="video-wrap" style="border:none;padding:0">
          <iframe src={`${data.video}&autoplay=0`} allowfullscreen></iframe>
        </div>
      </div>
    )}

    {data.comment && (
      <div class="section" style="padding:20px 34px">
        <div class="st">▎档案注脚</div>
        <div class="cmt" style="border:none;padding:0">
          <div class="ct" set:html={commentHtml} />
        </div>
      </div>
    )}

    {data.essay && (
      <div class="essay">
        <div class="et">▎档案编者按</div>
        <Fragment set:html={essayHtml} />
      </div>
    )}

    {data.tags && data.tags.length > 0 && (
      <div class="section" style="padding:20px 34px">
        <div class="st">▎标签</div>
        <div class="tag-strip" style="border:none;padding:0">
          {data.tags.map(t => <span>{t}</span>)}
        </div>
      </div>
    )}

    {data.end_section && data.end_section.length > 0 && (
      <div class="section" style="padding:20px 34px">
        <div class="st">▎档案印象</div>
        <div class="end-section" style="border:none;padding:0">
          {data.end_section.map(e => (
            <div>
              <div class="en" set:html={e.num}></div>
              <div class="eu" set:html={e.unit}></div>
              <div class="ed" set:html={e.desc} />
            </div>
          ))}
        </div>
      </div>
    )}

    {data.relics && data.relics.length > 0 && (
      <div class="section" style="padding:20px 34px">
        <div class="st">▎时代物证陈列柜</div>
        <div class="relics-cabinet">
          {data.relics.map((relic, index) => (
            <div class="relic-cell">
              <div class="relic-glass"></div>
              <div class="relic-showcase">
                <div class="relic-shadow-art">
                  <svg viewBox="0 0 64 64" class="relic-svg-silhouette">
                    <circle cx="32" cy="32" r="24" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 3" opacity="0.15" />
                    <path d="M22,32 L42,32 M32,22 L32,42" stroke="currentColor" stroke-width="0.5" opacity="0.1" />
                    <rect x="22" y="22" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3" />
                    <text x="32" y="34" font-size="7" font-family="monospace" text-anchor="middle" fill="currentColor" opacity="0.4">No.{index + 1}</text>
                  </svg>
                </div>
                <div class="relic-label-paper">
                  <div class="relic-id">No. ODD-{slug.substring(0, 3).toUpperCase()}-{index + 1}</div>
                  <div class="relic-name">{relic.name}</div>
                </div>
              </div>
              <div class="relic-info-panel">
                <div class="relic-info-title">{relic.name}</div>
                <div class="relic-info-desc">{relic.desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="footer" set:html={data.footer} />
  </div>
  <div class="imprint"><span>◈</span> 档 案 馆 藏 <span>◈</span></div>
  <script is:inline define:vars={{ scores }}>
    function playStampSound() {
      const AudioContext = window.AudioContext || window.webkitAudioContext;
      if (!AudioContext) return;
      try {
        const ctx = new AudioContext();
        
        const osc = ctx.createOscillator();
        const gainOsc = ctx.createGain();
        osc.type = 'triangle';
        osc.frequency.setValueAtTime(120, ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(30, ctx.currentTime + 0.15);
        gainOsc.gain.setValueAtTime(0.7, ctx.currentTime);
        gainOsc.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.15);
        osc.connect(gainOsc);
        gainOsc.connect(ctx.destination);
        
        const click = ctx.createOscillator();
        const gainClick = ctx.createGain();
        click.type = 'sine';
        click.frequency.setValueAtTime(1000, ctx.currentTime);
        click.frequency.exponentialRampToValueAtTime(150, ctx.currentTime + 0.04);
        gainClick.gain.setValueAtTime(0.5, ctx.currentTime);
        gainClick.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.04);
        click.connect(gainClick);
        gainClick.connect(ctx.destination);

        const bufferSize = ctx.sampleRate * 0.06;
        const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }
        const noise = ctx.createBufferSource();
        noise.buffer = buffer;
        
        const filter = ctx.createBiquadFilter();
        filter.type = 'bandpass';
        filter.frequency.value = 350;
        filter.Q.value = 2.0;
        
        const gainNoise = ctx.createGain();
        gainNoise.gain.setValueAtTime(0.3, ctx.currentTime);
        gainNoise.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.06);
        noise.connect(filter);
        filter.connect(gainNoise);
        gainNoise.connect(ctx.destination);
        
        osc.start();
        osc.stop(ctx.currentTime + 0.18);
        click.start();
        click.stop(ctx.currentTime + 0.06);
        noise.start();
        noise.stop(ctx.currentTime + 0.06);
      } catch(err) {
        console.error("Stamp audio error:", err);
      }
    }

    function playBookFlipSound() {
      const AudioContext = window.AudioContext || window.webkitAudioContext;
      if (!AudioContext) return;
      try {
        const ctx = new AudioContext();
        const bufferSize = ctx.sampleRate * 0.4;
        const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }
        const noise = ctx.createBufferSource();
        noise.buffer = buffer;
        
        const filter = ctx.createBiquadFilter();
        filter.type = 'bandpass';
        filter.frequency.setValueAtTime(1000, ctx.currentTime);
        filter.frequency.exponentialRampToValueAtTime(1500, ctx.currentTime + 0.3);
        filter.Q.value = 1.0;
        
        const gain = ctx.createGain();
        gain.gain.setValueAtTime(0.01, ctx.currentTime);
        gain.gain.linearRampToValueAtTime(0.12, ctx.currentTime + 0.08);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.38);
        
        noise.connect(filter);
        filter.connect(gain);
        gain.connect(ctx.destination);
        
        noise.start();
        noise.stop(ctx.currentTime + 0.4);
      } catch(err) {
        console.error("Book flip audio error:", err);
      }
    }

    function initDetailPage() {
      const wrap = document.querySelector('.wrap');
      
      // 0. 播放翻书声音
      if (wrap) {
        try {
          playBookFlipSound();
        } catch(e) {
          console.error(e);
        }
      }

      // 1. 绑定返回目录的 3D 合页动效
      const backLink = document.querySelector('.back-link');
      if (backLink && !backLink.dataset.bound) {
        backLink.dataset.bound = "true";
        backLink.addEventListener('click', (e) => {
          e.preventDefault();
          const targetUrl = backLink.getAttribute('href') || '/';
          if (wrap && wrap.classList.contains('page-closing')) return;
          
          try {
            playBookFlipSound();
          } catch(err) {
            console.error("Flip sound error:", err);
          }
          
          if (wrap) {
            // 直接导航，无合页动画
          }
          
          setTimeout(() => {
            window.location.href = targetUrl;
          }, 0);
        });
      }

      // 2. 盖章降临动效
      const stamp = document.getElementById('impactStamp');
      if (stamp) {
        setTimeout(() => {
          stamp.classList.add('landed');
          
          try {
            playStampSound();
          } catch(e) {
            console.error(e);
          }
          
          document.body.style.animation = 'screen-shake-light 0.4s ease';
          setTimeout(() => {
            document.body.style.animation = '';
          }, 400);
        }, 350);
      }

      // 3. 解密动效 (Decrypt Effect)
      try {
        const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789%@#$*&+-=_?';
        const decryptEls = document.querySelectorAll('.decrypt-text');
        
        decryptEls.forEach(el => {
          const originalText = el.getAttribute('data-text') || el.textContent || '';
          if (!originalText) return;
          let iterations = 0;
          const interval = setInterval(() => {
            el.textContent = originalText.split('').map((char, index) => {
              if (index < iterations) {
                return originalText[index];
              }
              return chars[Math.floor(Math.random() * chars.length)];
            }).join('');
            
            if (iterations >= originalText.length) {
              clearInterval(interval);
              el.textContent = originalText;
            }
            iterations += 1/3;
          }, 30);
        });
      } catch(err) {
        console.error("Decrypt effect error:", err);
      }

      // 4. 动态 SVG 雷达图生成与动画
      try {
        const radar = document.getElementById('radar-chart');
        if (radar) {
          const labels = ['国民度', '争议性', '荒诞性', '时代切片', '叙事弧光', '原生性'];
          const dimensions = ['popularity', 'dispute', 'absurdity', 'slice', 'narrative', 'native'];
          const values = dimensions.map(d => scores[d] || 5);
          const center = 110;
          const maxRadius = 75;
          const angleStep = Math.PI / 3;

          function createSVGEl(type, attrs = {}) {
            const el = document.createElementNS('http://www.w3.org/2000/svg', type);
            for (const [key, val] of Object.entries(attrs)) {
              el.setAttribute(key, val);
            }
            return el;
          }

          // 绘制 5 层背景同心六边形网格
          for (let level = 1; level <= 5; level++) {
            const radius = (level / 5) * maxRadius;
            const points = [];
            for (let i = 0; i < 6; i++) {
              const angle = i * angleStep - Math.PI / 2;
              const x = center + radius * Math.cos(angle);
              const y = center + radius * Math.sin(angle);
              points.push(`${x},${y}`);
            }
            radar.appendChild(createSVGEl('polygon', {
              class: 'radar-grid',
              points: points.join(' ')
            }));
          }

          // 绘制 6 条轴线与文本标签
          for (let i = 0; i < 6; i++) {
            const angle = i * angleStep - Math.PI / 2;
            
            const axisX = center + maxRadius * Math.cos(angle);
            const axisY = center + maxRadius * Math.sin(angle);
            radar.appendChild(createSVGEl('line', {
              class: 'radar-axis',
              x1: center,
              y1: center,
              x2: axisX,
              y2: axisY
            }));

            const textRadius = maxRadius + 18;
            const textX = center + textRadius * Math.cos(angle);
            let textY = center + textRadius * Math.sin(angle);
            if (i === 0) textY -= 2;      
            else if (i === 3) textY += 8; 
            else textY += 3;              

            const textEl = createSVGEl('text', {
              class: 'radar-label',
              x: textX,
              y: textY,
              'data-index': i
            });
            textEl.textContent = labels[i];
            radar.appendChild(textEl);
          }

          // 绘制实际得分多边形
          const poly = createSVGEl('polygon', {
            class: 'radar-poly',
            points: Array(6).fill(`${center},${center}`).join(' ')
          });
          radar.appendChild(poly);

          // 绘制顶点圆点
          const dots = [];
          for (let i = 0; i < 6; i++) {
            const dot = createSVGEl('circle', {
              class: 'radar-dot',
              cx: center,
              cy: center,
              r: 3,
              'data-index': i
            });
            radar.appendChild(dot);
            dots.push(dot);
          }

          let startTime = null;
          const duration = 800; 

          function animate(timestamp) {
            if (!startTime) startTime = timestamp;
            const progress = Math.min((timestamp - startTime) / duration, 1);
            const easeProgress = 1 - Math.pow(1 - progress, 3);

            const currentPoints = [];
            for (let i = 0; i < 6; i++) {
              const angle = i * angleStep - Math.PI / 2;
              const currentVal = values[i] * easeProgress;
              const radius = (currentVal / 10) * maxRadius;
              const x = center + radius * Math.cos(angle);
              const y = center + radius * Math.sin(angle);
              
              currentPoints.push(`${x},${y}`);
              
              dots[i].setAttribute('cx', x);
              dots[i].setAttribute('cy', y);
            }
            
            poly.setAttribute('points', currentPoints.join(' '));

            if (progress < 1) {
              requestAnimationFrame(animate);
            } else {
              const progressBars = document.querySelectorAll('.score-item .sb-bar');
              progressBars.forEach(bar => {
                const item = bar.closest('.score-item');
                const val = item.getAttribute('data-val');
                bar.style.width = (val * 10) + '%';
              });
            }
          }

          setTimeout(() => {
            requestAnimationFrame(animate);
          }, 150);

          const scoreItems = document.querySelectorAll('.score-item');
          const labelEls = document.querySelectorAll('.radar-label');

          function highlightIndex(index) {
            if (index === null) {
              scoreItems.forEach(item => item.classList.remove('active'));
              labelEls.forEach(label => label.classList.remove('active'));
              dots.forEach(dot => dot.classList.remove('active'));
            } else {
              scoreItems[index].classList.add('active');
              const label = Array.from(labelEls).find(l => l.getAttribute('data-index') == index);
              if (label) label.classList.add('active');
              dots[index].classList.add('active');
            }
          }

          scoreItems.forEach(item => {
            item.addEventListener('mouseenter', () => {
              const idx = item.getAttribute('data-index');
              highlightIndex(idx);
            });
            item.addEventListener('mouseleave', () => {
              highlightIndex(null);
            });
          });

          dots.forEach(dot => {
            dot.addEventListener('mouseenter', () => {
              const idx = dot.getAttribute('data-index');
              highlightIndex(idx);
            });
            dot.addEventListener('mouseleave', () => {
              highlightIndex(null);
            });
          });
        }
      } catch(err) {
        console.error("Radar chart error:", err);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initDetailPage);
    } else {
      initDetailPage();
    }

    // BFCache 处理：使用命后变量防止监听器重复注册
    if (!window.__detailBfCacheBound) {
      window.__detailBfCacheBound = true;
      window.addEventListener('pageshow', (e) => {
        if (e.persisted) {
          initDetailPage();
        }
      });
    }
  </script>
</Layout>

