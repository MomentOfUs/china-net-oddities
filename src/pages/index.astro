  @keyframes thread-spin {
    0% { transform: rotate(0deg); opacity: 0.9; }
    100% { transform: rotate(-360deg); opacity: 0.2; }
  }

  /* 火漆印 (Wax Seal) */
  .wax-seal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 96px;
    height: 96px;
    background: radial-gradient(circle, #c62828 0%, #b71c1c 80%, #7f0000 100%);
    border-radius: 48% 52% 51% 49% / 50% 48% 52% 50%; /* 模拟手捏火漆不规则圆形 */
    box-shadow: 
      0 4px 10px rgba(0,0,0,0.55),
      inset 0 2px 4px rgba(255,255,255,0.25);
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, opacity 0.5s ease;
  }
  .wax-seal:hover {
    transform: translate(-50%, -50%) scale(1.03);
  }
  .wax-seal:active {
    transform: translate(-50%, -50%) scale(0.97);
  }
  .seal-inner {
    width: 72px;
