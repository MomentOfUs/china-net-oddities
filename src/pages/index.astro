---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getAvatar } from '../utils/imageResolver';
import { Image } from 'astro:assets';

const rawEntries = await getCollection('phenomenon');

const getCategory = (tag) => {
  const t = tag || '';
  if (t.includes('网红') || t.includes('整活') || t.includes('鬼畜') || t.includes('大红大绿') || t.includes('流量') || t.includes('主播')) {
    return '网红整活';
  }
  if (t.includes('图腾') || t.includes('符号') || t.includes('风暴眼') || t.includes('领袖') || t.includes('导师') || t.includes('狂飙') || t.includes('标志')) {
    return '文化符号';
  }
  return '时代草根';
};

// 按照 home_metadata 进行列表整理
const entries = rawEntries.map(item => {
  const data = item.data;
  const metaInfo = data.home_metadata || { tag: '未分类', meta: '', stats: [] };
  const scores = data.scores || { popularity: 5, dispute: 5, absurdity: 5, slice: 5, narrative: 5, native: 5 };
  return {
    filename: `/${item.id}.html`,
    avatar: getAvatar(item.id, data.avatar),
    title: data.title || '',
    tag: metaInfo.tag,
    meta: metaInfo.meta,
    stats: metaInfo.stats || [],
    searchText: (data.title + ' ' + (metaInfo.meta || '') + ' ' + (data.tags || []).join(' ') + ' ' + (data.subtitle || '') + ' ' + (metaInfo.tag || '')).toLowerCase(),
    category: getCategory(metaInfo.tag),
    scores: scores,
    score: Object.values(scores).reduce((a, b) => a + b, 0)
  };
}).sort((a, b) => a.title.localeCompare(b.title, 'zh-cn'));
---
<Layout title="中国互联网奇观 · 人物档案馆">
  <div class="wrap">
    <div class="hero">
      <a href="/charte" class="charte-link">入选标准</a>
      <h1>中 国 互 联 网 奇 观</h1>
      <div class="sub">人 物 档 案 馆</div>
      <div class="classification">公 开</div>
      <div class="desc">这里没有网红，只有在围观与挣扎中，被时代重力碾成的命运标本。</div>
      <div style="text-align:center;margin-top:20px">
        <span class="evidence-tag">· 已核实档案 ·</span> 
        <span class="filing-num">No. 2024-25</span>
      </div>
    </div>

    <div class="entries">
      <div class="entry-head" style="margin-bottom:12px">馆 藏 目 录</div>
      
      <!-- 卷宗分类选择器 -->
      <div class="filter-tabs">
        <button class="filter-tab active" data-cat="all">全部卷宗</button>
        <button class="filter-tab" data-cat="网红整活">网红与整活</button>
        <button class="filter-tab" data-cat="文化符号">文化图腾</button>
        <button class="filter-tab" data-cat="时代草根">时代草根</button>
      </div>

      <!-- 排序切换 -->
      <div class="sort-tabs">
        <span class="sort-label">排序&#8195</span>
        <button class="sort-tab active" data-sort="name">按首字母</button>
        <button class="sort-tab" data-sort="score">按评分</button>
      </div>

      <!-- 动态评分筛选器面板 -->
      <div class="score-filters-panel">
        <div class="panel-trigger" onclick="toggleScoreFilter()">
          <span>⚙ 动态机密指标筛选器 (展开/收起)</span>
          <span class="trigger-arrow">▼</span>
        </div>
        <div class="panel-content">
          <div class="filter-row">
            <div class="filter-col">
              <span class="fl">国民度 ≥ <b id="val-popularity">0</b></span>
              <input type="range" class="filter-slider" id="slide-popularity" min="0" max="10" value="0" />
            </div>
            <div class="filter-col">
              <span class="fl">争议性 ≥ <b id="val-dispute">0</b></span>
              <input type="range" class="filter-slider" id="slide-dispute" min="0" max="10" value="0" />
            </div>
            <div class="filter-col">
              <span class="fl">荒诞性 ≥ <b id="val-absurdity">0</b></span>
              <input type="range" class="filter-slider" id="slide-absurdity" min="0" max="10" value="0" />
            </div>
          </div>
          <div class="filter-row" style="margin-top:10px">
            <div class="filter-col">
              <span class="fl">时代切片性 ≥ <b id="val-slice">0</b></span>
              <input type="range" class="filter-slider" id="slide-slice" min="0" max="10" value="0" />
            </div>
            <div class="filter-col">
              <span class="fl">叙事弧光 ≥ <b id="val-narrative">0</b></span>
              <input type="range" class="filter-slider" id="slide-narrative" min="0" max="10" value="0" />
            </div>
            <div class="filter-col">
              <span class="fl">原生性 ≥ <b id="val-native">0</b></span>
              <input type="range" class="filter-slider" id="slide-native" min="0" max="10" value="0" />
            </div>
          </div>
          <div style="text-align:right;margin-top:12px">
            <button class="reset-filter-btn" onclick="resetFilters()">重置筛选条件</button>
          </div>
        </div>
      </div>

      <div class="search-section">
        <div class="search-bar">
          <span class="search-label">▎档案检索</span>
          <div class="search-inner">
            <input type="text" id="searchInput" class="search-input" placeholder="姓名 · 标签 · 关键词" oninput="doSearch()" autocomplete="off" />
            <span id="searchClear" class="search-clear" onclick="document.getElementById('searchInput').value='';applyFilters();this.style.opacity='0'">✕</span>
          </div>
          <span id="searchCount" class="search-count"></span>
        </div>
      </div>

      <div class="entries-grid">
        {entries.map(entry => (
          <div class="fc-wrapper phenomenon-card" 
               style="position:relative; transition: opacity 0.4s ease, transform 0.4s ease"
               data-search={entry.searchText}
               data-category={entry.category}
               data-popularity={entry.scores.popularity}
               data-dispute={entry.scores.dispute}
               data-absurdity={entry.scores.absurdity}
               data-slice={entry.scores.slice}
               data-narrative={entry.scores.narrative}
               data-native={entry.scores.native}
               data-score={entry.score}>
            <div class="folder-tab">人物档案</div>
            <a class="featured" href={entry.filename}>
              {entry.avatar && entry.avatar.endsWith('.svg') ? (
                <img src={entry.avatar} alt={entry.title} class="fc-img" width={360} height={360} />
              ) : (
              <Image 
                src={entry.avatar} 
                alt={entry.title} 
                width={360} 
                height={360} 
                format="webp" 
                inferSize={true}
                class="fc-img" 
              />
              )}
              <div class="fc-body">
                <div class="fc-tag">{entry.tag}</div>
                <div class="fc-title">{entry.title}</div>
                <div class="fc-meta" set:html={entry.meta}></div>
                <div class="fc-stats">
                  {entry.stats.map(stat => (
                    <span><b>{stat.val}</b>{stat.label}</span>
                  ))}
                </div>
                <div class="fc-link">查阅档案</div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Suggestion Wall ── -->
    <div class="suggest-section">
      <div class="entry-head">▎请愿墙</div>
      <div class="suggest-form" id="suggestForm">
        <input type="text" id="suggestInput" placeholder="你想在这里看到谁？" maxlength="40" autocomplete="off" />
        <button id="suggestBtn" onclick="submitSuggestion()">提交</button>
      </div>
      <div class="suggest-msg" id="suggestMsg"></div>
      <div class="entry-head" style="margin-top:12px">▎已有建议</div>
      <div id="suggestList" class="suggest-list"><div class="suggest-empty">加载中...</div></div>
    </div>

    <div class="footer">
      <span id="vcounter" style="cursor:help;color:#6a5a4a;letter-spacing:5px" title="同IP每小时只计1次">◈ 访客 − ◈</span>
      <br /><span style="opacity:.4">🦞 麻辣小龙虾 · 持续更新</span>
    </div>
  </div>

  <script is:inline>
    (async function(){
      try{
        let r=await fetch('/api/count',{method:'POST'});
        let d=await r.json();
        document.getElementById('vcounter').textContent='◈ 访客 ' + d.count + ' ◈';
      }catch(e){
        document.getElementById('vcounter').textContent='◈ 访客 − ◈';
      }
    })();

    async function loadSuggestions(){
      const el=document.getElementById('suggestList');
      try{
        const r=await fetch('/api/suggestions');
        const d=await r.json();
        if(!d.suggestions||d.suggestions.length===0){
          el.innerHTML='<div class="suggest-empty">还没有建议，来写第一个吧</div>';
          return;
        }
        el.innerHTML=d.suggestions.map(s=>
          '<span class="suggest-item">'+s.name.replace(/</g,'&lt;')+'</span>'
        ).join('');
      }catch(e){
        el.innerHTML='<div class="suggest-empty">加载失败</div>';
      }
    }

    async function submitSuggestion(){
      const input=document.getElementById('suggestInput');
      const btn=document.getElementById('suggestBtn');
      const msg=document.getElementById('suggestMsg');
      const name=input.value.trim();
      if(!name){msg.className='suggest-msg err';msg.textContent='输入不能为空';return}
      btn.disabled=true;btn.textContent='提交中';
      msg.className='suggest-msg';
      msg.textContent='';
      try{
        const r=await fetch('/api/suggest',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name})});
        const d=await r.json();
        if(r.ok){
          msg.className='suggest-msg ok';
          msg.textContent='已收到，谢谢建议 🦞';
          input.value='';
          loadSuggestions();
        }else{
          msg.className='suggest-msg err';
          msg.textContent=d.error||'提交失败';
        }
      }catch(e){
        msg.className='suggest-msg err';
        msg.textContent='网络错误，请重试';
      }
      btn.disabled=false;btn.textContent='提交';
    }

    loadSuggestions();

    /* ── 排序切换 ── */
    let currentSort = 'name';

    function sortCards(sortBy) {
      const container = document.querySelector('.entries-grid');
      const cards = Array.from(container.querySelectorAll('.phenomenon-card'));

      cards.sort((a, b) => {
        if (sortBy === 'name') {
          return a.querySelector('.fc-title').textContent.localeCompare(
            b.querySelector('.fc-title').textContent, 'zh'
          );
        } else {
          return (parseFloat(b.getAttribute('data-score')) || 0) -
                 (parseFloat(a.getAttribute('data-score')) || 0);
        }
      });

      cards.forEach(c => container.appendChild(c));
      currentSort = sortBy;
    }

    document.querySelectorAll('.sort-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const sortBy = tab.getAttribute('data-sort');
        if (sortBy === currentSort) return;
        document.querySelectorAll('.sort-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        sortCards(sortBy);
      });
    });

    document.getElementById('suggestInput').addEventListener('keydown',function(e){if(e.key==='Enter')submitSuggestion()});

    /* ── Admin ── */
    let adminClickCount = 0;
    let adminClickTimer = null;

    document.querySelector('.footer').addEventListener('click', function(e) {
      if (e.target.tagName === 'SPAN' || e.target.closest('.footer')) {
        adminClickCount++;
        clearTimeout(adminClickTimer);
        adminClickTimer = setTimeout(() => { adminClickCount = 0; }, 2000);
        if (adminClickCount >= 5) {
          adminClickCount = 0;
          openAdmin();
        }
      }
    });

    function openAdmin() {
      window.location.href = '/admin';
    }
    /* ── 动态指标面板的收起/展开 ── */
    window.toggleScoreFilter = function() {
      const panel = document.querySelector('.score-filters-panel');
      panel.classList.toggle('open');
    }

    // 过滤逻辑
    let currentCategory = 'all';
    const sliders = ['popularity', 'dispute', 'absurdity', 'slice', 'narrative', 'native'];
    const filterValues = {
      popularity: 0,
      dispute: 0,
      absurdity: 0,
      slice: 0,
      narrative: 0,
      native: 0
    };

    function applyFilters() {
      const cards = document.querySelectorAll('.phenomenon-card');
      const searchQuery = (document.getElementById('searchInput')?.value || '').toLowerCase().trim();
      let visibleCount = 0;

      cards.forEach(card => {
        const cat = card.getAttribute('data-category');
        const scores = {
          popularity: parseInt(card.getAttribute('data-popularity') || '0'),
          dispute: parseInt(card.getAttribute('data-dispute') || '0'),
          absurdity: parseInt(card.getAttribute('data-absurdity') || '0'),
          slice: parseInt(card.getAttribute('data-slice') || '0'),
          narrative: parseInt(card.getAttribute('data-narrative') || '0'),
          native: parseInt(card.getAttribute('data-native') || '0')
        };

        const catMatch = (currentCategory === 'all' || cat === currentCategory);

        let scoreMatch = true;
        for (const s of sliders) {
          if (scores[s] < filterValues[s]) {
            scoreMatch = false;
            break;
          }
        }

        let searchMatch = true;
        if (searchQuery) {
          const searchData = (card.getAttribute('data-search') || '').toLowerCase();
          searchMatch = searchData.indexOf(searchQuery) !== -1;
        }

        if (catMatch && scoreMatch && searchMatch) {
          card.style.display = 'block';
          visibleCount++;
          // 延迟应用透明度以显示淡入动画
          setTimeout(() => {
            card.style.opacity = '1';
            card.style.transform = 'scale(1)';
          }, 20);
        } else {
          card.style.opacity = '0';
          card.style.transform = 'scale(0.95)';
          setTimeout(() => {
            if (card.style.opacity === '0') {
              card.style.display = 'none';
            }
          }, 400);
        }
      });

      const countEl = document.getElementById('searchCount');
      if (countEl) {
        countEl.textContent = visibleCount + ' / ' + cards.length;
      }
    }

    window.doSearch = function() {
      const input = document.getElementById('searchInput');
      const clearBtn = document.getElementById('searchClear');
      if (input && clearBtn) {
        clearBtn.style.opacity = input.value ? '1' : '0';
      }
      applyFilters();
    }

    document.getElementById('searchInput')?.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        this.value = '';
        applyFilters();
        this.blur();
      }
    });

    // 绑定分类 Tab 事件
    document.querySelectorAll('.filter-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        currentCategory = tab.getAttribute('data-cat');
        applyFilters();
      });
    });

    // 绑定滑动条事件
    sliders.forEach(s => {
      const slider = document.getElementById('slide-' + s);
      const valLabel = document.getElementById('val-' + s);
      if (slider && valLabel) {
        slider.addEventListener('input', (e) => {
          const val = parseInt(e.target.value);
          valLabel.textContent = val;
          filterValues[s] = val;
          applyFilters();
        });
      }
    });

    // 重置按钮
    window.resetFilters = function() {
      sliders.forEach(s => {
        const slider = document.getElementById('slide-' + s);
        const valLabel = document.getElementById('val-' + s);
        if (slider && valLabel) {
          slider.value = 0;
          valLabel.textContent = '0';
          filterValues[s] = 0;
        }
      });
      const searchInput = document.getElementById('searchInput');
      if (searchInput) searchInput.value = '';
      applyFilters();
    }
  </script>
</Layout>

<style>
  /* ── 卷宗过滤分类 Tabs ── */
  .filter-tabs {
    display: flex;
    gap: 12px;
    margin: 0 36px 16px;
    flex-wrap: wrap;
  }
  .filter-tab {
    background: rgba(13, 11, 9, 0.6);
    border: 1px solid rgba(197, 168, 128, 0.18);
    color: #8a7a6a;
    padding: 6px 16px;
    font-size: 10px;
    letter-spacing: 3px;
    cursor: pointer;
    font-family: 'Noto Serif SC', serif;
    transition: all 0.3s;
  }
