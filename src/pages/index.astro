  }
  .hero::after{
    content:'';position:absolute;bottom:-1px;left:32px;right:32px;height:1px;
    background:linear-gradient(90deg,transparent,rgba(197,168,128,0.2) 10%,rgba(197,168,128,0.1) 50%,rgba(197,168,128,0.2) 90%,transparent)
  }
  .hero::before{
    content:'';position:absolute;top:0;left:0;right:0;bottom:0;
    background:
      radial-gradient(ellipse 60% 30% at 50% 40%,rgba(197,168,128,0.012) 0%,transparent 70%),
      repeating-linear-gradient(180deg,transparent,transparent 3px,rgba(197,168,128,0.012) 3px,rgba(197,168,128,0.012) 4px);
    pointer-events:none;
