  }

  /* ── 排序切换 ── */
  .sort-tabs {
    display: flex;
    gap: 8px;
    margin: -8px 36px 16px;
    align-items: center;
  }
  .sort-label {
    font-size: 9px;
    color: #6a5a4a;
    letter-spacing: 3px;
    font-family: 'Times New Roman', Georgia, serif;
  }
  .sort-tab {
    background: rgba(13, 11, 9, 0.6);
    border: 1px solid rgba(197, 168, 128, 0.12);
    color: #7a6a5a;
    padding: 3px 12px;
    font-size: 9px;
    letter-spacing: 2px;
    cursor: pointer;
    font-family: 'Noto Serif SC', serif;
    transition: all 0.3s;
  }
  .sort-tab:hover {
    border-color: rgba(197, 168, 128, 0.35);
    color: #c5a880;
  }
  .sort-tab.active {
    background: rgba(197, 168, 128, 0.1);
    border-color: rgba(197, 168, 128, 0.4);
    color: #e6dfd3;
  }

  /* ── 机密指标筛选面板 ── */
  .score-filters-panel {
    margin: 0 36px 24px;
    border: 1px solid rgba(197, 168, 128, 0.15);
    background: rgba(13, 11, 9, 0.3);
  }
  .panel-trigger {
    padding: 10px 18px;
    font-size: 9px;
    color: #8a7a6a;
    letter-spacing: 2px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(197, 168, 128, 0.02);
    transition: background 0.3s, color 0.3s;
    user-select: none;
  }
  .panel-trigger:hover {
    background: rgba(197, 168, 128, 0.06);
    color: #c5a880;
  }
  .trigger-arrow {
    transition: transform 0.3s;
    font-size: 8px;
  }
  .score-filters-panel.open .trigger-arrow {
    transform: rotate(180deg);
  }
  .panel-content {
    padding: 16px 20px;
    border-top: 1px solid rgba(197, 168, 128, 0.1);
    display: none;
  }
  .score-filters-panel.open .panel-content {
    display: block;
  }
  .filter-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .filter-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .filter-col .fl {
    font-size: 10px;
    color: #7a6a5a;
    letter-spacing: 1px;
    display: flex;
    justify-content: space-between;
  }
  .filter-col b {
    color: #c5a880;
    font-family: 'Times New Roman', Georgia, serif;
  }
  .filter-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 3px;
    background: rgba(197, 168, 128, 0.15);
    outline: none;
    border-radius: 2px;
    transition: background 0.3s;
  }
  .filter-slider:hover {
    background: rgba(197, 168, 128, 0.3);
  }
  .filter-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
