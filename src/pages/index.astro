---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Stamp from '../components/Stamp.astro';
import { getCollection } from 'astro:content';
import { getAvatar } from '../utils/imageResolver';
import { Image } from 'astro:assets';

const rawEntries = await getCollection('phenomenon');

const getCategory = (tag) => {
  const t = tag || '';
  if (t.includes('网红') || t.includes('整活') || t.includes('鬼畜') || t.includes('大红大绿') || t.includes('流量') || t.includes('主播')) {
    return '网红整活';
  }
  if (t.includes('图腾') || t.includes('符号') || t.includes('风暴眼') || t.includes('领袖') || t.includes('导师') || t.includes('狂飙') || t.includes('标志')) {
    return '文化符号';
  }
  return '时代草根';
};

// 从 english_name 派生全拼、逐字首字母、英文别名、分词拼音
// 深度支持括号内/外及多段拼音的分词提取 (如 "Chen E (Basket Boy / Dai Lanzi)" -> ce, dlz, chene, dailanzi)
function getPinyinTokens(englishName) {
  if (!englishName) return '';
  
  let parts = [];
  
  // 提取括号/中文括号内的内容
  const parenRe = /[\(\（](.+?)[\)\）]/g;
  let match;
  const rawAliasList = [];
  while ((match = parenRe.exec(englishName)) !== null) {
    rawAliasList.push(match[1]);
  }
  
  // 移除括号部分得到括号外的主体
  const rawMain = englishName.replace(/[\(\（].+?[\)\）]/g, ' ').trim();
  
  // 支持以斜杠、分号、逗号、加号或竖线拆分为子项
  const splitRe = /[\/,\;\+\|]/;
  
  if (rawMain) {
    rawMain.split(splitRe).forEach(s => parts.push(s.trim()));
  }
  rawAliasList.forEach(alias => {
    alias.split(splitRe).forEach(s => parts.push(s.trim()));
  });
  
  const tokens = new Set();
  // 拼音音节切割正则
  const syllableRe = /(zh|ch|sh|[bpmfdtnlgkhjqxzcsryw])?(iang|iong|uang|uai|ian|iao|ang|eng|ing|ong|ueng|[aeiouv]{1,2}(?:ng|n)?)/gi;

  parts.forEach(part => {
    // 移除非英数字、空白和连字符
    const cleanPart = part.toLowerCase().replace(/[^a-z0-9\s-]/g, '').trim();
    if (!cleanPart) return;
    
    const words = cleanPart.split(/[\s-]+/).filter(Boolean);
    if (words.length === 0) return;
    
    tokens.add(cleanPart);
    tokens.add(words.join(''));
    
    const syllables = words.flatMap(w => {
      const ms = w.match(syllableRe);
      return ms && ms.length > 0 ? ms : [w];
    });
    
    if (syllables.length > 0) {
      tokens.add(syllables.join(' '));
      const initials = syllables.map(s => s[0] || '').join('');
      if (initials) {
        tokens.add(initials);
      }
    }
  });
  
  return Array.from(tokens).filter(Boolean).join(' ');
}

// 中文标题与拼音、首字母的静态映射表（不仅包含中文标题本身，还涵盖了人物的真实本名、核心网名、外号及梗，确保全维度拼音覆盖）
const namePinyinMap = {
  "阿Giao": { pinyin: "a giao zhan yapeng hei mao jing zhang", initials: "ag zyp hmjz" },
  "常熟阿诺": { pinyin: "changshu a nuo sheng yi tao an", initials: "csan syt an" },
  "带篮子": { pinyin: "dai lan zi chen leng jing chen e ce lz", initials: "dlz clj ce lz" },
  "刀哥": { pinyin: "dao ge er ci yuan dao jiang dj", initials: "dg ecydj dj" },
  "丁胖子金牌讲师（雷森）": { pinyin: "ding pang zi jin pai jiang shi lei sen ls jpjs js", initials: "dpzjpjsls ls jpjs js" },
  "丁真": { pinyin: "ding zhen zhen zhu dzzz zz", initials: "dz dzzz zz" },
  "东北雨姐": { pinyin: "dong bei yu jie chang xiao yu cxy yj", initials: "dbyj cxy yj" },
  "反诈警官老陈": { pinyin: "fan zha jing guan lao chen chen guo ping cgp lc xcgg xi chang gong gong", initials: "fzjglc cgp lc xcgg" },
  "范小勤": { pinyin: "fan xiao qin xiao ma yun xmy", initials: "fxq xmy" },
  "疯狂小杨哥": { pinyin: "feng kuang xiao yang ge zhang qing yang zqy xyg szy san zhi yang", initials: "fkxyg zqy xyg szy" },
  "峰哥": { pinyin: "feng ge zhou li feng zlf zbf zi ben feng plm po luo men", initials: "fg zlf zbf plm" },
  "嘎子": { pinyin: "ga zi xie meng wei xmw pgzj pan ga zhi jiao", initials: "gz xmw pgzj" },
  "郭老师": { pinyin: "guo lao shi guo bei bei gbb ysml ye si mo la", initials: "gls gbb ysml" },
  "虎哥": { pinyin: "hu ge chai hao ch cls chai lao shi", initials: "hg ch cls" },
  "户晨风": { pinyin: "hu chen feng hu sheng hs", initials: "hcf hs" },
  "姜萍": { pinyin: "jiang ping tcsn tian cai shao nv", initials: "jp tcsn" },
  "牢A": { pinyin: "lao a alex skqdw si kui qi da wang skq", initials: "la alex skqdw skq" },
  "李佳琦": { pinyin: "li jia qi dhyg dai huo yi ge hxz hua xi zi", initials: "ljq dhyg hxz" },
  "李子柒": { pinyin: "li zi qi li jia jia ljj", initials: "lzq ljj" },
  "丽丽": { pinyin: "li li liu jian long ljl dwdsz dai wei dong shi zhang tbal tu bu a long", initials: "ll ljl dwdsz tbal" },
  "良子": { pinyin: "liang zi li zhan liang lzl", initials: "lz lzl" },
  "流浪大师（沈巍）": { pinyin: "liu lang da shi shen wei sw llds lldssw", initials: "llds sw lldssw" },
  "留几手": { pinyin: "liu ji shou liu shuang ls sg shou ge", initials: "ljs ls sg" },
  "卢本伟": { pinyin: "lu ben wei wwk wu wu kai 55k 55kai lbh lu ben huang", initials: "lbw wwk 55k lbh" },
  "马保国": { pinyin: "ma bao guo hyxytjqzm hun yuan xing yi tai ji quan zhang men tjds tai ji da shi", initials: "mbg hyxytjqzm tjds" },
  "🐴牛逼": { pinyin: "ma niu bi mnb", initials: "mnb" },
  "猫一杯": { pinyin: "mao yi bei xu jia yi xjy blsy ba li shi yi", initials: "myb xjy blsy" },
  "窃格瓦拉": { pinyin: "qie ge wa la zhou li qi zlq as a san", initials: "qgwl zlq as" },
  "三和大神": { pinyin: "san he da shen hj hong jie glpd gua lu pi dan gk gua kao", initials: "shds hj glpd gk" },
  "沙马特团长": { pinyin: "sha ma te tuan zhang luo fu xing lfx smt sha ma te", initials: "smttz lfx smt" },
  "神鹰黑手": { pinyin: "shen ying hei shou liang hong bing lhb sy hs yg ying ge", initials: "syhs lhb sy hs yg" },
  "孙笑川": { pinyin: "sun xiao chuan dddsx dai dai da shi xiong sg sun gou cxdz chou xiang dai zhu", initials: "sxc dddsx sg cxdz" },
  "铁山靠": { pinyin: "tie shan kao kao ge kg ds dao shi", initials: "tsk kg ds" },
  "铁头": { pinyin: "tie tou dong guang ming dgm", initials: "tt dgm" },
  "王伟恒": { pinyin: "wang wei heng lzwb lang zi wu bo wb wu bo zxbw zou xian ba wang", initials: "wvh lzwb wb zxbw" },
  "晚晚": { pinyin: "wan wan lei wan ying lwy wn wan niang", initials: "ww lwy wn" },
  "吴京": { pinyin: "wu jing zhan lang zl jg jing ge", initials: "wj zl jg" },
  "秀才": { pinyin: "xiu cai xu ya jun xyj", initials: "xc xyj" },
  "徐勤根": { pinyin: "xu qin gen rlgzlnx ren lei gao zhi liang nan xing gzlnx gao zhi liang nan xing", initials: "xqg rlgzlnx gzlnx" },
  "杨笠": { pinyin: "yang li pxnds pu xin nan dao shi lj li jie", initials: "yl pxnds lj" },
  "药水哥": { pinyin: "yao shui ge liu bo lb yj yao jiang ysj yi shu jia", initials: "ysg lb yj ysj" },
  "殷世航": { pinyin: "yin shi hang hang zi hz az ai zi", initials: "ysh hz az" },
  "张雪峰": { pinyin: "zhang xue feng zhang zi biao zzb kyms kao yan名师", initials: "zxf zzb kyms" },
  "庞麦郎": { pinyin: "pang mai lang wu di wd yshpml yue se han pang mai lang", initials: "pml wd yshpml" }
};

// 按照 home_metadata 进行列表整理
const entries = rawEntries.map(item => {
  const data = item.data;
  const metaInfo = data.home_metadata || { tag: '未分类', meta: '', stats: [] };
  const scores = data.scores || { popularity: 5, dispute: 5, absurdity: 5, slice: 5, narrative: 5, native: 5 };
  const namePinyin = namePinyinMap[data.title] || { pinyin: '', initials: '' };
  
  return {
    filename: `/${item.id}.html`,
    avatar: getAvatar(item.id, data.avatar),
    title: data.title || '',
    tag: metaInfo.tag,
    meta: metaInfo.meta,
    stats: metaInfo.stats || [],
    searchText: (data.title + ' ' + (metaInfo.meta || '') + ' ' + (data.tags || []).join(' ') + ' ' + (data.subtitle || '') + ' ' + (metaInfo.tag || '') + ' ' + getPinyinTokens(data.english_name) + ' ' + namePinyin.pinyin + ' ' + namePinyin.initials).toLowerCase(),
    category: getCategory(metaInfo.tag),
    scores: scores,
    score: Object.values(scores).reduce((a, b) => a + b, 0),
    clearance: data.clearance || 'D'
  };
}).sort((a, b) => a.title.localeCompare(b.title, 'zh-cn'));
---
<Layout title="中国互联网奇观 · 人物档案馆">
  <!-- 档案袋封面 -->
  <div id="archive-envelope" class="archive-envelope-overlay">
    <div class="envelope-body">
      <div class="envelope-content">
        <!-- 封口线绳绕扣 -->
        <div class="string-tie-box">
          <div class="string-button upper-button" id="envelope-button-upper"></div>
          <svg class="tie-thread-svg" width="100" height="120" viewBox="0 0 100 120">
            <path id="tie-thread-path" d="M 50 10 L 50 110" stroke="#5d4b3c" stroke-width="2" stroke-dasharray="3 3" fill="none" />
          </svg>
          <div class="string-button lower-button" id="envelope-button-lower"></div>
        </div>

        <!-- 机密封缄火漆印 -->
        <div class="wax-seal" id="envelope-seal">
          <div class="seal-inner">
            <span class="seal-mark">极密</span>
          </div>
        </div>

        <!-- 封皮印章 -->
        <div class="envelope-stamp">
          <div class="e-stamp-inner">
            <div class="e-stamp-title">DECLASSIFIED</div>
            <div class="e-stamp-level">网络奇观案卷</div>
            <div class="e-stamp-date">No. ARCHIVE-2026</div>
          </div>
        </div>

        <!-- 封皮纸标签 -->
        <div class="envelope-label">
          <div class="label-title">中国互联网奇观人物档案馆</div>
          <div class="label-meta">馆藏卷宗 · 肆拾肆件全</div>
          <div class="label-action-hint">点击火漆印或绕线扣启封</div>
        </div>
      </div>
    </div>
  </div>

  <!-- 印章油墨滤镜 -->
  <svg width="0" height="0" style="position:absolute">
    <defs>
      <filter id="stamp-filter" x="-5%" y="-5%" width="110%" height="110%">
        <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="3" seed="2" result="noise"/>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="1.2" xChannelSelector="R" yChannelSelector="G"/>
      </filter>
    </defs>
  </svg>
  <div class="wrap" id="main-content">
    <div class="hero">
      <a href="/charte" class="charte-link">入选标准</a>
      <h1>中 国 互 联 网 奇 观</h1>
      <div class="sub">人 物 档 案 馆</div>
      <div class="classification">公 开</div>
      <div class="desc">这里没有网红，只有在围观与挣扎中，被时代重力碾成的命运标本。</div>
      <div class="hero-stats-bar">
        <span class="evidence-tag">已核实档案 · {entries.length} 件</span>
        <span class="filing-num"><span class="lvl-a">A</span>·{rawEntries.filter(e => e.data.clearance === 'A').length} <span class="lvl-b">B</span>·{rawEntries.filter(e => e.data.clearance === 'B').length} <span class="lvl-c">C</span>·{rawEntries.filter(e => e.data.clearance === 'C').length} <span class="lvl-d">D</span>·{rawEntries.filter(e => e.data.clearance === 'D').length}</span>
      </div>
    </div>

    <div class="entries">
      <SectionHeading title="馆 藏 目 录" count={entries.length + ' 件'} />
      
      <!-- 排序切换 -->
      <div class="sort-tabs">
        <span class="sort-label"><span class="sort-icon">⛓</span> 档案索引排序</span>
        <button class="sort-tab active" data-sort="name"><span class="sort-tab-icon">A–Z</span> 按首字母</button>
        <button class="sort-tab" data-sort="score"><span class="sort-tab-icon">★</span> 按综合评分</button>
      </div>

      <div id="entriesData" data-urls={JSON.stringify(entries.map(e => e.filename))} style="display:none"></div>

      <div class="search-section">
        <div class="search-bar">
          <span class="search-label">▎档案检索</span>
          <div class="search-inner">
            <input type="text" id="searchInput" class="search-input" placeholder="姓名 · 标签 · 关键词" oninput="doSearch()" autocomplete="off" />
            <span id="searchClear" class="search-clear" onclick="document.getElementById('searchInput').value='';applyFilters();this.style.opacity='0'">✕</span>
          </div>
          <span id="searchCount" class="search-count"></span>
        </div>
        <div class="oracle-book-corner" id="oracleTrigger" title="翻开下一页：随机命运调档">
          <div class="book-corner-page"></div>
          <div class="book-corner-rivet"></div>
          <div class="book-corner-numbers">No. ??</div>
          <div class="book-corner-text">命运调档</div>
          <div class="book-corner-arrow">➔</div>
        </div>
      </div>

      <div class="entries-grid">
        {entries.map(entry => (
          <div class="fc-wrapper phenomenon-card"
               style="position:relative; transition: opacity 0.4s ease, transform 0.4s ease"
               data-search={entry.searchText}
               data-category={entry.category}
               data-clearance={entry.clearance}
               data-popularity={entry.scores.popularity}
               data-dispute={entry.scores.dispute}
               data-absurdity={entry.scores.absurdity}
               data-slice={entry.scores.slice}
               data-narrative={entry.scores.narrative}
               data-native={entry.scores.native}
               data-score={entry.score}>
            <a class="featured" href={entry.filename}>
              <div class="folder-tab">人物档案</div>
              <div class={`clearance-stamp stamp-level-${entry.clearance}`}>
                <span class="stamp-inner">{entry.clearance}级解密</span>
              </div>
              <div class="fc-photo-wrap">
                {entry.avatar && entry.avatar.endsWith('.svg') ? (
                  <img src={entry.avatar} alt={entry.title} class="fc-img" width={360} height={360} />
                ) : (
                <Image 
                  src={entry.avatar} 
                  alt={entry.title} 
                  width={360} 
                  height={360} 
                  format="webp" 
                  inferSize={true}
                  loading="lazy"
                  decoding="async"
                  class="fc-img" 
                />
                )}
              </div>
              <div class="fc-body">
                <div class="fc-tag">{entry.tag}</div>
                <div class="fc-title">{entry.title}</div>
                <div class="fc-meta" set:html={entry.meta}></div>
                <div class="fc-stats">
                  {entry.stats.map(stat => (
                    <span><b>{stat.val}</b>{stat.label}</span>
                  ))}
                </div>
                <div class="fc-link">查阅档案</div>
              </div>
            </a>
          </div>
        ))}
      </div>

      <!-- 搜索空状态 -->
      <div id="searchEmpty" class="search-empty" style="display:none">
        <div class="empty-icon">🔍</div>
        <div class="empty-title">未找到相关人物档案</div>
        <div class="empty-desc">建议更换姓名、拼音缩写或特征词重新检索</div>
      </div>
    </div>

    <!-- ── Suggestion Wall ── -->
    <div class="suggest-section">
      <div class="entry-head">▎请愿墙</div>
      <div class="suggest-form" id="suggestForm">
        <input type="text" id="suggestInput" placeholder="你想在这里看到谁？" maxlength="40" autocomplete="off" />
        <button id="suggestBtn" onclick="submitSuggestion()">提交</button>
      </div>
      <div class="suggest-msg" id="suggestMsg"></div>
      <div class="entry-head" style="margin-top:12px">▎已有建议</div>
      <div id="suggestList" class="suggest-list"><div class="suggest-empty">加载中...</div></div>
    </div>

    <div class="footer">
      <span id="vcounter" style="cursor:help;color:var(--c-text-faint);letter-spacing:5px" title="同IP每小时只计1次">◈ 访客 − ◈</span>
      <br /><span style="opacity:.4">🦞 麻辣小龙虾 · 持续更新</span>
    </div>
  </div>

  <script is:inline>
    // 翻书声音由 /audio.js 全局模块提供

    // 2. 通用页面初始化函数，兼容浏览器 DOM 缓存
    function initHomepage() {
      // 2.1 绑定随机命运调档 (折角书签)
      const oracleTrigger = document.getElementById('oracleTrigger');
      if (oracleTrigger) {
        if (!oracleTrigger.dataset.bound) {
          oracleTrigger.dataset.bound = "true";
          oracleTrigger.addEventListener('click', () => {
            const wrap = document.querySelector('.wrap');
            if (wrap && wrap.classList.contains('page-flipping')) return;

            try {
              if (window.__archiveAudio && window.__archiveAudio.playBookFlipSound) {
                window.__archiveAudio.playBookFlipSound();
              }
            } catch(err) {
              console.error("Oracle audio error:", err);
            }
            if (wrap) wrap.classList.add('page-flipping');

            // 编号闪烁：No.?? 快速跳动
            const numEl = document.querySelector('.book-corner-numbers');
            if (numEl) {
              const total = 43; // 馆藏总数
              let flashCount = 0;
              const flashInterval = setInterval(() => {
                numEl.textContent = 'No.' + String(Math.floor(Math.random() * total) + 1).padStart(2, '0');
                flashCount++;
                if (flashCount >= 12) {
                  clearInterval(flashInterval);
                  numEl.textContent = 'No. ??';
                }
              }, 50);
            }

            setTimeout(() => {
              const dataEl = document.getElementById('entriesData');
              if (dataEl) {
                const urls = JSON.parse(dataEl.getAttribute('data-urls') || '[]');
                if (urls.length > 0) {
                  const randomUrl = urls[Math.floor(Math.random() * urls.length)];
                  if (wrap) wrap.classList.remove('page-flipping');
                  window.location.href = randomUrl;
                }
              }
            }, 420);
          });
        }
      }

      // 2.2 绑定卡片翻页
      const cards = document.querySelectorAll('.phenomenon-card a');
      cards.forEach(card => {
        if (!card.dataset.bound) {
          card.dataset.bound = "true";
          card.addEventListener('click', (e) => {
            e.preventDefault();
            const targetUrl = card.getAttribute('href');
            try {
              if (window.__archiveAudio && window.__archiveAudio.playPaperRustleSound) {
                window.__archiveAudio.playPaperRustleSound();
              } else if (window.__archiveAudio && window.__archiveAudio.playBookFlipSound) {
                window.__archiveAudio.playBookFlipSound();
              }
            } catch(err) {
              console.error("Card click audio error:", err);
            }
            setTimeout(() => {
              if (targetUrl) {
                window.location.href = targetUrl;
              }
            }, 0);
          });
        }
      });
      // 页面初始化或返回时同步检索状态
      applyFilters();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHomepage);
    } else {
      initHomepage();
    }

    // 处理 BFCache：当用户点击浏览器返回时，移除残留的 page-flipping 动画状态
    window.addEventListener('pageshow', (e) => {
      if (e.persisted) {
        const wrap = document.querySelector('.wrap');
        if (wrap) {
          wrap.classList.remove('page-flipping');
        }
      }
    });


    (async function(){
      try{
        let r=await fetch('/api/count',{method:'POST'});
        let d=await r.json();
        document.getElementById('vcounter').textContent='◈ 访客 ' + d.count + ' ◈';
      }catch(e){
        document.getElementById('vcounter').textContent='◈ 访客 − ◈';
      }
    })();

    async function loadSuggestions(){
      const el=document.getElementById('suggestList');
      try{
        const r=await fetch('/api/suggestions');
        const d=await r.json();
        if(!d.suggestions||d.suggestions.length===0){
          el.innerHTML='<div class="suggest-empty">还没有建议，来写第一个吧</div>';
          return;
        }
        el.innerHTML=d.suggestions.map(s=>
          '<span class="suggest-item">'+s.name.replace(/</g,'&lt;')+'</span>'
        ).join('');
      }catch(e){
        el.innerHTML='<div class="suggest-empty">加载失败</div>';
      }
    }

    async function submitSuggestion(){
      const input=document.getElementById('suggestInput');
      const btn=document.getElementById('suggestBtn');
      const msg=document.getElementById('suggestMsg');
      const name=input.value.trim();
      if(!name){msg.className='suggest-msg err';msg.textContent='输入不能为空';return}
      btn.disabled=true;btn.textContent='提交中';
      msg.className='suggest-msg';
      msg.textContent='';
      try{
        const r=await fetch('/api/suggest',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name})});
        const d=await r.json();
        if(r.ok){
          msg.className='suggest-msg ok';
          msg.textContent='已收到，谢谢建议 🦞';
          input.value='';
          loadSuggestions();
        }else{
          msg.className='suggest-msg err';
          msg.textContent=d.error||'提交失败';
        }
      }catch(e){
        msg.className='suggest-msg err';
        msg.textContent='网络错误，请重试';
      }
      btn.disabled=false;btn.textContent='提交';
    }

    loadSuggestions();

    /* ── 排序切换 ── */
    let currentSort = 'name';

    function sortCards(sortBy) {
      const container = document.querySelector('.entries-grid');
      const cards = Array.from(container.querySelectorAll('.phenomenon-card'));

      cards.sort((a, b) => {
        if (sortBy === 'name') {
          return a.querySelector('.fc-title').textContent.localeCompare(
            b.querySelector('.fc-title').textContent, 'zh'
          );
        } else {
          return (parseFloat(b.getAttribute('data-score')) || 0) -
                 (parseFloat(a.getAttribute('data-score')) || 0);
        }
      });

      cards.forEach(c => container.appendChild(c));
      currentSort = sortBy;
    }

    document.querySelectorAll('.sort-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const sortBy = tab.getAttribute('data-sort');
        if (sortBy === currentSort) return;
        document.querySelectorAll('.sort-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        sortCards(sortBy);
      });
    });

    document.getElementById('suggestInput').addEventListener('keydown',function(e){if(e.key==='Enter')submitSuggestion()});

    /* ── Admin ── */
    let adminClickCount = 0;
    let adminClickTimer = null;

    document.querySelector('.footer').addEventListener('click', function(e) {
      if (e.target.tagName === 'SPAN' || e.target.closest('.footer')) {
        adminClickCount++;
        clearTimeout(adminClickTimer);
        adminClickTimer = setTimeout(() => { adminClickCount = 0; }, 2000);
        if (adminClickCount >= 5) {
          adminClickCount = 0;
          openAdmin();
        }
      }
    });

    function openAdmin() {
      window.location.href = '/admin';
    }
    function applyFilters() {
      const cards = document.querySelectorAll('.phenomenon-card');
      const inputEl = document.getElementById('searchInput');
      const searchQuery = (inputEl?.value || '').toLowerCase().trim();
      let visibleCount = 0;

      // 同步清除按钮状态
      const clearBtn = document.getElementById('searchClear');
      if (clearBtn && inputEl) {
        clearBtn.style.opacity = inputEl.value ? '1' : '0';
      }

      cards.forEach(card => {
        let searchMatch = true;
        if (searchQuery) {
          const searchData = (card.getAttribute('data-search') || '').toLowerCase();
          const queryWords = searchQuery.split(/\s+/).filter(Boolean);
          searchMatch = queryWords.every(word => searchData.indexOf(word) !== -1);
        }

        if (searchMatch) {
          card.classList.remove('filtered-out');
          card.classList.add('card-visible');
          visibleCount++;
        } else {
          card.classList.add('filtered-out');
        }
      });

      const countEl = document.getElementById('searchCount');
      if (countEl) {
        countEl.textContent = visibleCount + ' / ' + cards.length;
      }

      // 控制空状态显隐
      const emptyEl = document.getElementById('searchEmpty');
      if (emptyEl) {
        emptyEl.style.display = (searchQuery && visibleCount === 0) ? 'block' : 'none';
      }
    }

    window.doSearch = function() {
      applyFilters();
    }

    document.getElementById('searchInput')?.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        this.value = '';
        applyFilters();
        this.blur();
      }
    });

    /* ── 卡片入场交错动画 ── */
    function initCardEntrance() {
      const cards = document.querySelectorAll('.phenomenon-card');
      if (!cards.length || !('IntersectionObserver' in window)) {
        cards.forEach(c => c.classList.add('card-visible'));
        return;
      }
      const cardsArray = Array.from(cards);

      // 兜底：3 秒后尚未显示的卡片全部亮出
      let fallbackTimer = setTimeout(() => {
        cardsArray.forEach(c => {
          if (!c.classList.contains('card-visible')) {
            c.style.animationDelay = '0ms';
            c.classList.add('card-visible');
          }
        });
      }, 3000);

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const card = entry.target;
            const index = cardsArray.indexOf(card);
            // 每行 3 张，同行微错开 40ms，换行加 25ms —— 快速但有层次
            const row = Math.floor(index / 3);
            const col = index % 3;
            card.style.animationDelay = (col * 40 + row * 25) + 'ms';
            card.classList.add('card-visible');
            observer.unobserve(card);
            // 全部显示则清除兜底
            if (cardsArray.every(c => c.classList.contains('card-visible'))) {
              clearTimeout(fallbackTimer);
            }
          }
        });
      }, { threshold: 0.05, rootMargin: '0px 0px 120px 0px' });
      // threshold 0.05 → 露一点就触发
      // rootMargin 120px → 提前 120px 预热，快滑不空白

      cardsArray.forEach(c => observer.observe(c));
    }

    /* ── 卡片照片 3D 倾斜 ── */
    function initPhotoTilt() {
      document.querySelectorAll('.featured').forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          const img = card.querySelector('.fc-img');
          if (img) {
            img.style.transform = `perspective(400px) rotateY(${x * 14}deg) rotateX(${-y * 10}deg) scale(1.04)`;
            img.style.transition = 'transform 0.1s ease-out';
            img.style.filter = 'grayscale(0.15) sepia(0.06) contrast(1.06) brightness(0.88) saturate(0.85)';
          }
        });
        card.addEventListener('mouseleave', () => {
          const img = card.querySelector('.fc-img');
          if (img) {
            img.style.transform = '';
            img.style.filter = '';
            img.style.transition = '';
          }
        });
      });
    }

    /* ── 图片懒加载渐入 ── */
    function initImgFadeIn() {
      document.querySelectorAll('.fc-img').forEach(img => {
        if (img.complete && img.naturalWidth > 0) {
          img.classList.add('img-loaded');
        } else {
          img.addEventListener('load', () => img.classList.add('img-loaded'), { once: true });
          img.addEventListener('error', () => img.classList.add('img-loaded'), { once: true });
        }
      });
    }
    initImgFadeIn();
    initCardEntrance();
    initPhotoTilt();

    /* ── 检索框“打字机击键”声效绑定 ── */
    (function(){
      var searchInput = document.getElementById('searchInput');
      if (!searchInput) return;
      searchInput.addEventListener('keydown', function(e) {
        if (window.__archiveAudio) {
          if (e.key === 'Backspace') {
            window.__archiveAudio.playTypewriterClickSound(true);
          } else if (e.key === 'Enter') {
            window.__archiveAudio.playTypewriterBellSound();
          } else if (e.key.length === 1 || e.key === ' ') {
            window.__archiveAudio.playTypewriterClickSound(false);
          }
        }
      });
    })();

    /* ── 机密档案袋启封仪式感控制 ── */
    (function(){
      var envelope = document.getElementById('archive-envelope');
      if (!envelope) return;
      
      var isOpened = sessionStorage.getItem('archive-envelope-opened') === '1';
      if (isOpened) {
        envelope.style.display = 'none';
      } else {
        // 锁定滚动条以获得完整沉浸感
        document.documentElement.style.overflow = 'hidden';
        document.body.style.overflow = 'hidden';
      }

      var seal = document.getElementById('envelope-seal');
      var btnUpper = document.getElementById('envelope-button-upper');
      var btnLower = document.getElementById('envelope-button-lower');
      var thread = document.querySelector('.tie-thread-svg');

      var unwrapping = false;

      function triggerUnwrap() {
        if (unwrapping) return;
        unwrapping = true;
        
        // 阶段 1: 火漆印碎裂
        if (window.__archiveAudio) {
          window.__archiveAudio.playWaxSealCrackSound();
        }
        if (seal) {
          seal.classList.add('cracked');
        }
        
        setTimeout(function() {
          // 阶段 2: 绕扣线绳转动松开
          if (window.__archiveAudio) {
            window.__archiveAudio.playStringUnwrapSound();
          }
          if (thread) {
            thread.classList.add('unwrapping');
          }
          
          // 阶段 3: 案卷上下飞退，信封开启
          setTimeout(function() {
            if (window.__archiveAudio) {
              window.__archiveAudio.playPaperRustleSound();
            }
            envelope.classList.add('opened');
            
            // 恢复页面滚动条
            document.documentElement.style.overflow = '';
            document.body.style.overflow = '';
            sessionStorage.setItem('archive-envelope-opened', '1');
            
            setTimeout(function() {
              envelope.style.display = 'none';
            }, 800);
          }, 1200); // 绕线两圈的时长
        }, 300);
      }

      if (seal) seal.addEventListener('click', triggerUnwrap);
      if (btnUpper) btnUpper.addEventListener('click', triggerUnwrap);
      if (btnLower) btnLower.addEventListener('click', triggerUnwrap);
    })();

    /* ── 重新封存案卷按钮 ── */
    (function(){
      function renderRecloseBtn() {
        var existing = document.getElementById('envelope-reclose-btn');
        if (existing) return;
        var footer = document.querySelector('.footer');
        if (!footer) {
          setTimeout(renderRecloseBtn, 300);
          return;
        }
        var btn = document.createElement('span');
        btn.id = 'envelope-reclose-btn';
        btn.textContent = '🔒 重新封存案卷';
        btn.title = '重新封存并体验档案袋开箱仪式';
        btn.style.cssText = 'cursor:pointer;margin-left:14px;font-size:10px;opacity:0.5;transition:opacity 0.2s;';
        
        btn.addEventListener('mouseenter', function () { btn.style.opacity = '1'; });
        btn.addEventListener('mouseleave', function () { btn.style.opacity = '0.5'; });
        btn.addEventListener('click', function () {
          try {
            if (window.__archiveAudio) {
              window.__archiveAudio.playStampSound();
            }
          } catch(e){}
          
          sessionStorage.removeItem('archive-envelope-opened');
          window.location.reload();
        });
        footer.appendChild(btn);
      }
      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', renderRecloseBtn);
      } else {
        renderRecloseBtn();
      }
    })();
  </script>
</Layout>

<style>
  /* ── 首页档案启封袋 ── */
  .archive-envelope-overlay {
    position: fixed;
    inset: 0;
    z-index: 100000;
