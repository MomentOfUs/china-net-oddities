---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getAvatar } from '../utils/imageResolver';
import { Image } from 'astro:assets';

const rawEntries = await getCollection('phenomenon');

// 按照 home_metadata 进行列表整理
const entries = rawEntries.map(item => {
  const data = item.data;
  const metaInfo = data.home_metadata || { tag: '未分类', meta: '', stats: [] };
  return {
    filename: `/${item.id}.html`,
    avatar: getAvatar(item.id, data.avatar),
    title: data.title || '',
    tag: metaInfo.tag,
    meta: metaInfo.meta,
    stats: metaInfo.stats || [],
  };
});
---
<Layout title="中国互联网奇观 · 人物档案馆">
  <div class="wrap">
    <div class="hero">
      <a href="/charte" class="charte-link">入选标准</a>
      <h1>中 国 互 联 网 奇 观</h1>
      <div class="sub">人 物 档 案 馆</div>
      <div class="classification">公 开</div>
      <div class="desc">这里没有网红，只有在围观与挣扎中，被时代重力碾成的命运标本。</div>
      <div style="text-align:center;margin-top:20px">
        <span class="evidence-tag">· 已核实档案 ·</span> 
        <span class="filing-num">No. 2024-25</span>
      </div>
    </div>

    <div class="entries">
      <div class="entry-head" style="margin-bottom:20px">馆 藏 目 录</div>
      <div class="entries-grid">
        {entries.map(entry => (
          <div class="fc-wrapper" style="position:relative">
            <div class="folder-tab">人物档案</div>
            <a class="featured" href={entry.filename}>
              <Image 
                src={entry.avatar} 
                alt={entry.title} 
                width={360} 
                height={360} 
                format="webp" 
                inferSize={true}
                class="fc-img" 
              />
              <div class="fc-body">
                <div class="fc-tag">{entry.tag}</div>
                <div class="fc-title">{entry.title}</div>
                <div class="fc-meta" set:html={entry.meta}></div>
                <div class="fc-stats">
                  {entry.stats.map(stat => (
                    <span><b>{stat.val}</b>{stat.label}</span>
                  ))}
                </div>
                <div class="fc-link">查阅档案</div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Suggestion Wall ── -->
    <div class="suggest-section">
      <div class="entry-head">▎请愿墙</div>
      <div class="suggest-form" id="suggestForm">
        <input type="text" id="suggestInput" placeholder="你想在这里看到谁？" maxlength="40" autocomplete="off" />
        <button id="suggestBtn" onclick="submitSuggestion()">提交</button>
      </div>
      <div class="suggest-msg" id="suggestMsg"></div>
      <div class="entry-head" style="margin-top:12px">▎已有建议</div>
      <div id="suggestList" class="suggest-list"><div class="suggest-empty">加载中...</div></div>
    </div>

    <div class="footer">
      <span id="vcounter" style="cursor:help;color:#6a5a4a;letter-spacing:5px" title="同IP每小时只计1次">◈ 访客 − ◈</span>
      <br /><span style="opacity:.4">🦞 麻辣小龙虾 · 持续更新</span>
    </div>
  </div>

  <script is:inline>
    (async function(){
      try{
        let r=await fetch('/api/count',{method:'POST'});
        let d=await r.json();
        document.getElementById('vcounter').textContent='◈ 访客 ' + d.count + ' ◈';
      }catch(e){
        document.getElementById('vcounter').textContent='◈ 访客 − ◈';
      }
    })();

    async function loadSuggestions(){
      const el=document.getElementById('suggestList');
      try{
        const r=await fetch('/api/suggestions');
        const d=await r.json();
        if(!d.suggestions||d.suggestions.length===0){
          el.innerHTML='<div class="suggest-empty">还没有建议，来写第一个吧</div>';
          return;
        }
        el.innerHTML=d.suggestions.map(s=>
          '<span class="suggest-item">'+s.name.replace(/</g,'&lt;')+'</span>'
        ).join('');
      }catch(e){
        el.innerHTML='<div class="suggest-empty">加载失败</div>';
      }
    }

    async function submitSuggestion(){
      const input=document.getElementById('suggestInput');
      const btn=document.getElementById('suggestBtn');
      const msg=document.getElementById('suggestMsg');
      const name=input.value.trim();
      if(!name){msg.className='suggest-msg err';msg.textContent='输入不能为空';return}
      btn.disabled=true;btn.textContent='提交中';
      msg.className='suggest-msg';
      msg.textContent='';
      try{
        const r=await fetch('/api/suggest',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name})});
        const d=await r.json();
        if(r.ok){
          msg.className='suggest-msg ok';
          msg.textContent='已收到，谢谢建议 🦞';
          input.value='';
          loadSuggestions();
        }else{
          msg.className='suggest-msg err';
          msg.textContent=d.error||'提交失败';
        }
      }catch(e){
        msg.className='suggest-msg err';
        msg.textContent='网络错误，请重试';
      }
      btn.disabled=false;btn.textContent='提交';
    }

    loadSuggestions();

    document.getElementById('suggestInput').addEventListener('keydown',function(e){if(e.key==='Enter')submitSuggestion()});

    /* ── Admin ── */
    let adminClickCount = 0;
    let adminClickTimer = null;

    document.querySelector('.footer').addEventListener('click', function(e) {
      if (e.target.tagName === 'SPAN' || e.target.closest('.footer')) {
        adminClickCount++;
        clearTimeout(adminClickTimer);
        adminClickTimer = setTimeout(() => { adminClickCount = 0; }, 2000);
        if (adminClickCount >= 5) {
          adminClickCount = 0;
          openAdmin();
        }
      }
    });

    function openAdmin() {
      window.location.href = '/admin';
    }
  </script>
</Layout>

<style>
  /* ── Parchment Container ── */
  .wrap{
    max-width:1100px;margin:48px auto;position:relative;z-index:2;
    background:linear-gradient(175deg,rgba(16,13,10,0.88) 0%,rgba(10,8,6,0.92) 100%);
    border: 3px double rgba(197, 168, 128, 0.25);
    box-shadow:
      0 0 0 1px rgba(80,65,50,0.1),
      0 0 0 2px rgba(12,10,8,0.7),
      0 10px 80px rgba(0,0,0,0.7),
      inset 0 0 80px rgba(0,0,0,0.3);
    padding:0 0 1px 0
  }

  /* ── Hero ── */
  .hero{
    padding:90px 30px 60px;text-align:center;position:relative;
    border-bottom:1px solid rgba(197, 168, 128, 0.15)
  }
  .hero::after{
    content:'';position:absolute;bottom:-1px;left:32px;right:32px;height:1px;
    background:linear-gradient(90deg,transparent,rgba(197,168,128,0.2) 10%,rgba(197,168,128,0.1) 50%,rgba(197,168,128,0.2) 90%,transparent)
  }
  .hero::before{
    content:'';position:absolute;top:-50%;left:0;right:0;height:250%;
    background:radial-gradient(ellipse 60% 30% at 50% 40%,rgba(197,168,128,0.035) 0%,transparent 70%);pointer-events:none
  }
  .hero h1{
    font-size:54px;font-weight:400;color:#e6dfd3;letter-spacing:22px;line-height:1.2;
    text-shadow:0 3px 12px rgba(0,0,0,0.5),0 0 60px rgba(197,168,128,0.06);
    font-family:'ZCOOL XiaoWei','Noto Serif SC',serif;font-weight:900
  }
  .hero .sub{
    font-size:11px;color:#8c7c6c;margin-top:16px;letter-spacing:10px;font-weight:300;
    position:relative;display:inline-block
  }
  .hero .sub::before,.hero .sub::after{
    content:'◆';font-size:5px;color:#8a7a6a;margin:0 14px;vertical-align:middle;opacity:.4
  }
  .hero .desc{
    font-size:12px;color:#9a8a7a;max-width:520px;margin:28px auto 0;line-height:2.6;font-weight:300;
    letter-spacing:1px
  }
  .hero .desc::before{
    display:block;content:'❦';font-size:14px;color:rgba(197,168,128,0.25);margin-bottom:14px;font-family:Georgia,serif
  }

  /* ── Entry List ── */
  .entries{padding:36px 0}
  .entry-head{
    font-size:11px;color:#8a7a6a;letter-spacing:7px;text-transform:uppercase;font-weight:400;
    margin:0 36px 28px;padding-bottom:12px;position:relative;font-family:'Times New Roman',Georgia,serif
  }
  .entry-head::after{
    content:'';position:absolute;bottom:0;left:0;right:0;height:1px;
    background:linear-gradient(90deg,rgba(197,168,128,0.25) 15%,rgba(197,168,128,0.05) 50%,transparent)
  }

  /* ── Entry Grid ── */
  .entries-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin:0 36px 24px}

  /* ── folder tab ── */
  .fc-wrapper .folder-tab {
    position:absolute;
    top:-10px;
    left:12px;
    background:#0d0b09;
    border:1px solid rgba(197, 168, 128, 0.25);
    border-bottom:none;
    font-size:8px;
    color:#9a8a7a;
    padding:2px 8px;
    letter-spacing:2px;
    font-family:'Noto Serif SC',serif;
    z-index:5;
  }

  /* ── Featured Cards ── */
  .featured{display:block;padding:0;margin:0;
    transition:all .4s cubic-bezier(0.165, 0.84, 0.44, 1);text-decoration:none;color:inherit;position:relative;
    background:rgba(13,11,9,0.85);
    border:1px solid rgba(197,168,128,0.15);
    box-shadow:0 2px 8px rgba(0,0,0,0.3);
    overflow:hidden
  }
  .featured:hover{
    background:rgba(22,18,15,0.95);
    border-color:rgba(197,168,128,0.45);
    box-shadow:0 10px 30px rgba(197,168,128,0.08), 0 2px 8px rgba(0,0,0,0.4);
    transform:translateY(-3px)
  }
  .featured:hover .fc-link{color:#c5a880}
  .featured .fc-img{
    aspect-ratio:1/1;width:100%;object-fit:cover;object-position:center 30%;
    display:block;filter:grayscale(0.15) contrast(0.95) brightness(0.85);
    transition:filter 0.4s ease, transform 0.4s ease;
  }
  .featured:hover .fc-img{filter:grayscale(0) contrast(1) brightness(1);transform:scale(1.03)}
  .featured .fc-body{padding:16px 18px 18px;display:flex;flex-direction:column;justify-content:center}
  .featured .fc-tag{font-size:8px;color:#c5a880;letter-spacing:3px;text-transform:uppercase;font-weight:300}
  .featured .fc-title{
    font-size:20px;font-weight:600;color:#e6dfd3;letter-spacing:6px;margin-top:6px;
    font-family:'Noto Serif SC','Source Han Serif SC',serif
  }
  .featured .fc-meta{font-size:10px;color:#8a7a6a;margin-top:6px;font-weight:300}
  .featured .fc-meta .hl{color:#c5a880}
  .featured .fc-stats{display:flex;gap:20px;margin-top:18px;flex-wrap:wrap}
  .featured .fc-stats span{font-size:9px;color:#7a6a5a;font-weight:300;letter-spacing:.3px}
  .featured .fc-stats b{
    color:#c5a880;font-size:14px;font-family:'Times New Roman',Georgia,serif;
    display:block;line-height:1;letter-spacing:1px;margin-bottom:2px
  }
  .featured .fc-link{
    display:inline-block;margin-top:18px;font-size:10px;color:#9a8a7a;
    text-decoration:none;letter-spacing:4px;transition:color .3s;font-weight:400;
    position:relative;padding-right:18px
  }
  .featured .fc-link::after{content:'→';position:absolute;right:0;transition:right .3s}
  .featured .fc-link:hover::after{right:-4px}

  /* ── Placeholder Grid ── */
  .card-grid{
    display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;
    margin:0 36px;
  }
  .card-grid>a{
    background:rgba(13,11,9,0.4);padding:40px 20px;text-align:center;
    text-decoration:none;transition:all .3s;
    border: 1px dashed rgba(197,168,128,0.18);
    display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:160px
  }
  .card-grid>a:hover{background:rgba(22,18,15,0.6);border-color:rgba(197,168,128,0.35)}
  .card-grid .ci{font-size:24px;margin-bottom:10px;opacity:.15;color:#c5a880}
  .card-grid .cn{font-size:13px;color:#7a6a5a;letter-spacing:6px;font-weight:300}
  .card-grid .cd{font-size:9px;color:#5a4a3a;margin-top:6px;letter-spacing:2px;font-weight:300}

  /* ── Suggestion Wall ── */
  .suggest-section{padding:36px 0 0}
  .suggest-form{margin:0 36px 24px;padding:24px 28px;background:rgba(13,11,9,0.5);border:1px solid rgba(197,168,128,0.15);display:flex;gap:12px;align-items:center;flex-wrap:wrap}
  .suggest-form input{flex:1;min-width:180px;padding:10px 16px;background:rgba(8,7,6,0.8);border:1px solid rgba(197,168,128,0.2);color:#e6dfd3;font-family:inherit;font-size:14px;letter-spacing:2px;outline:none;transition:all .3s}
  .suggest-form input:focus{border-color:rgba(197,168,128,0.45);box-shadow:inset 0 1px 4px rgba(0,0,0,0.5)}
  .suggest-form input::placeholder{color:#6a5a4a;letter-spacing:4px;font-size:11px}
  .suggest-form button{padding:10px 24px;background:rgba(197,168,128,0.12);border:1px solid rgba(197,168,128,0.25);color:#c5a880;font-family:inherit;font-size:11px;letter-spacing:6px;cursor:pointer;transition:all .3s}
  .suggest-form button:hover{background:rgba(197,168,128,0.25);border-color:rgba(197,168,128,0.45);color:#e6dfd3}
  .suggest-form button:disabled{opacity:.3;cursor:not-allowed}
  .suggest-msg{margin:0 36px;font-size:10px;letter-spacing:3px;min-height:20px}
  .suggest-msg.ok{color:#7a9a6a}
  .suggest-msg.err{color:#b05030}
  .suggest-list{margin:12px 36px 0;display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
  .suggest-item{padding:16px;background:rgba(13,11,9,0.5);border:1px solid rgba(197,168,128,0.15);font-size:14px;color:#bcae9e;letter-spacing:4px;text-align:center;cursor:default;transition:all .3s}
  .suggest-item:hover{background:rgba(22,18,15,0.8);border-color:rgba(197,168,128,0.35);color:#e6dfd3}
  .suggest-empty{font-size:10px;color:#6a5a4a;letter-spacing:4px;margin:0 36px;grid-column:1/-1;text-align:center;padding:20px 0}

  /* ── Colophon ── */
  .footer{
    padding:40px 30px 44px;text-align:center;font-size:8px;color:#5a4a3a;
    letter-spacing:3px;line-height:2.4;font-weight:300;
    border-top:1px solid rgba(197,168,128,0.15);position:relative
  }
  .footer::before{
    content:'';position:absolute;top:-1px;left:32px;right:32px;height:1px;
    background:linear-gradient(90deg,transparent,rgba(197,168,128,0.15) 10%,rgba(197,168,128,0.08) 50%,rgba(197,168,128,0.15) 90%,transparent)
  }

  /* ── Classification / Tags ── */
  .classification {
    position: absolute;
    top: 20px;
    right: 24px;
    font-size:9px;
    color:#b05030;
    border:1px solid rgba(176,80,48,0.35);
    padding:3px 10px;
    letter-spacing:4px;
    font-family:'Noto Serif SC',serif;
  }
  .charte-link {
    position: absolute;
    top: 20px;
    left: 24px;
    font-size: 9px;
    color: #c5a880;
    border: 1px solid rgba(197, 168, 128, 0.3);
    padding: 3px 10px;
    letter-spacing: 4px;
    font-family: 'Noto Serif SC', serif;
    text-decoration: none;
    transition: all 0.3s ease;
    background: rgba(197, 168, 128, 0.02);
  }
  .charte-link:hover {
    background: rgba(197, 168, 128, 0.08);
    border-color: rgba(197, 168, 128, 0.65);
    color: #e6dfd3;
    text-shadow: 0 0 4px rgba(197, 168, 128, 0.2);
  }
  .evidence-tag {
    font-size:8px;
    color:#8a7a6a;
    letter-spacing:3px;
  }
  .filing-num {
    font-size:8px;
    font-family:monospace;
    color:#c5a880;
  }

  /* ── Responsive ── */
  @media(max-width:640px){
    .wrap{margin:10px 6px}
    .hero{padding:54px 16px 40px}
    .hero h1{font-size:34px;letter-spacing:14px}
    .hero .sub::before,.hero .sub::after{display:none}
    .hero .sub{letter-spacing:6px}
    .charte-link {
      top: 14px;
      left: 14px;
      padding: 2px 6px;
      letter-spacing: 2px;
      font-size: 8px;
    }
    .classification {
      top: 14px;
      right: 14px;
      padding: 2px 6px;
      letter-spacing: 2px;
      font-size: 8px;
    }
    .featured{margin:0}
    .entries-grid{grid-template-columns:repeat(2,1fr);gap:10px;margin:0 10px}
    .featured .fc-img{aspect-ratio:1/1;width:100%}
    .featured .fc-body{padding:14px 16px}
    .featured .fc-title{font-size:18px;letter-spacing:4px}
    .card-grid{grid-template-columns:1fr;margin:0 10px;gap:10px}
    .card-grid>a{min-height:120px;padding:25px}
    .entry-head{margin-left:18px;margin-right:18px}
    .footer{padding:28px 16px 32px}
    .suggest-form{margin:0 16px 18px;padding:14px 16px}
    .suggest-list{margin:12px 16px 0;grid-template-columns:repeat(2,1fr)}
    .suggest-empty{margin:0 16px}
    .suggest-msg{margin:0 16px}
  }
</style>
