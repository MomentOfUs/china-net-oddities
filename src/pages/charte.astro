---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const rawEntries = await getCollection('phenomenon');

const sortedEntries = rawEntries.map(item => {
  const data = item.data;
  const scores = data.scores || { popularity: 5, dispute: 5, absurdity: 5, slice: 5, narrative: 5, native: 5 };
  const total = scores.popularity + scores.dispute + scores.absurdity + scores.slice + scores.narrative + scores.native;
  return {
    title: data.title,
    scores,
    total
  };
}).sort((a, b) => b.total - a.total);
---
<Layout title="入选标准 · 互联网奇观 · 人物档案馆">
  <div class="wrap" id="main-content">
    <div class="hero">
      <div class="top-back"><a href="/">← 返 回 档 案 馆</a></div>
      <h1>入 选 标 准</h1>
      <div class="sub">评 价 体 系</div>
      <div class="desc">为什么是他/她？凭什么入馆？<br />这里有一套标准，但不迷信标准。</div>
    </div>
    <div class="content">

      <!-- 总纲 -->
      <div class="section">
        <div class="s-h"><span class="num">△</span>总纲</div>
        <p class="no-indent" style="font-size:12px;color:var(--c-text-muted);letter-spacing:3px;line-height:2.4">
          这里没有网红，只有在围观与挣扎中，被时代重力碾成的命运标本。
        </p>
        <div class="quote-block">
          <em>❝</em>
          "互联网奇观"不等同于"网红"。<br />
          奇观是时代的切片——一个人被卷入或主动制造的文化现象，其存在本身就揭示了互联网时代的某种本质。
        </div>
      </div>

      <!-- 壹 -->
      <div class="section">
        <div class="s-h"><span class="num">壹</span>核心定义</div>
        <p><strong style="color:#c0a070;font-weight:400">互联网奇观</strong>是指在互联网上形成的、同时具备以下全部特征的公众人物或群体现象：</p>
        <div class="criteria-grid">
          <div class="criteria-item"><div class="ci-name">现象级</div><div class="ci-desc">跨越圈层，形成广泛社会讨论</div></div>
          <div class="criteria-item"><div class="ci-name">不可复制</div><div class="ci-desc">其走红路径无法被刻意模仿</div></div>
          <div class="criteria-item"><div class="ci-name">时代标本性</div><div class="ci-desc">承载着某个时期的社会情绪或文化矛盾</div></div>
          <div class="criteria-item"><div class="ci-name">叙事完整性</div><div class="ci-desc">有起承转合，构成一个可供讲述的故事</div></div>
        </div>
        <p>一个合格的奇观人物，其存在本身就值得被叙述——不是因为流量，而是因为象征意义。</p>
      </div>

      <!-- 贰 -->
      <div class="section">
        <div class="s-h"><span class="num">贰</span>六维评价体系</div>
        <p>每个候选人物按六个维度评分，满分 <strong style="color:#c0a070;font-weight:400">60</strong> 分。准入线 <strong style="color:#c0a070;font-weight:400">36</strong> 分。</p>

        <div class="criteria-box">
          <div class="criteria-header">一 · 国民度 <span class="dim-light">0–10</span></div>
          <p class="criteria-intro">大众知晓程度，不限于核心受众圈。</p>
          <div class="score-row"><span class="sr-label">0–3</span><div class="sr-bar"><div class="sr-fill" style="width:15%"></div></div></div>
          <div class="score-row"><span class="sr-label">4–6</span><div class="sr-bar"><div class="sr-fill" style="width:35%"></div></div></div>
          <div class="score-row"><span class="sr-label">7–8</span><div class="sr-bar"><div class="sr-fill" style="width:55%"></div></div></div>
          <div class="score-row"><span class="sr-label">9–10</span><div class="sr-bar"><div class="sr-fill high" style="width:75%"></div></div></div>
          <div class="score-notes">丁真 9 · 吴京 10</div>
        </div>

        <div class="criteria-box">
          <div class="criteria-header">二 · 争议性 <span class="dim-light">0–10</span></div>
          <p class="criteria-intro">讨论烈度与持续时长。零争议不构成奇观。</p>
          <div class="score-row"><span class="sr-label">0–2</span><div class="sr-bar"><div class="sr-fill" style="width:15%"></div></div></div>
          <div class="score-row"><span class="sr-label">3–5</span><div class="sr-bar"><div class="sr-fill" style="width:35%"></div></div></div>
          <div class="score-row"><span class="sr-label">6–8</span><div class="sr-bar"><div class="sr-fill" style="width:55%"></div></div></div>
          <div class="score-row"><span class="sr-label">9–10</span><div class="sr-bar"><div class="sr-fill high" style="width:75%"></div></div></div>
          <div class="score-notes">三和大神 7 · 范小勤 8</div>
        </div>

        <div class="criteria-box">
          <div class="criteria-header">三 · 荒诞性 <span class="dim-light">0–10</span></div>
          <p class="criteria-intro">离奇、意外、反常识。荒诞是奇观的核心美学。</p>
          <div class="score-row"><span class="sr-label">0–2</span><div class="sr-bar"><div class="sr-fill" style="width:15%"></div></div></div>
          <div class="score-row"><span class="sr-label">3–5</span><div class="sr-bar"><div class="sr-fill" style="width:35%"></div></div></div>
          <div class="score-row"><span class="sr-label">6–8</span><div class="sr-bar"><div class="sr-fill" style="width:55%"></div></div></div>
          <div class="score-row"><span class="sr-label">9–10</span><div class="sr-bar"><div class="sr-fill high" style="width:75%"></div></div></div>
          <div class="score-notes">王伟恒 8 · 良子 8</div>
        </div>

        <div class="criteria-box">
          <div class="criteria-header">四 · 时代切片性 <span class="dim-light">0–10</span></div>
          <p class="criteria-intro">能否作为某个时代节点的文化锚点。</p>
          <div class="score-row"><span class="sr-label">0–2</span><div class="sr-bar"><div class="sr-fill" style="width:15%"></div></div></div>
          <div class="score-row"><span class="sr-label">3–5</span><div class="sr-bar"><div class="sr-fill" style="width:35%"></div></div></div>
          <div class="score-row"><span class="sr-label">6–8</span><div class="sr-bar"><div class="sr-fill" style="width:55%"></div></div></div>
          <div class="score-row"><span class="sr-label">9–10</span><div class="sr-bar"><div class="sr-fill high" style="width:75%"></div></div></div>
          <div class="score-notes">三和大神 10（注脚一个时代）</div>
        </div>

        <div class="criteria-box">
          <div class="criteria-header">五 · 叙事弧光 <span class="dim-light">0–10</span></div>
          <p class="criteria-intro">故事的起承转合，是否有"剧本感"。</p>
          <div class="score-row"><span class="sr-label">0–2</span><div class="sr-bar"><div class="sr-fill" style="width:15%"></div></div></div>
          <div class="score-row"><span class="sr-label">3–5</span><div class="sr-bar"><div class="sr-fill" style="width:35%"></div></div></div>
          <div class="score-row"><span class="sr-label">6–8</span><div class="sr-bar"><div class="sr-fill" style="width:55%"></div></div></div>
          <div class="score-row"><span class="sr-label">9–10</span><div class="sr-bar"><div class="sr-fill high" style="width:75%"></div></div></div>
          <div class="score-notes">张雪峰 9 · 范小勤 9</div>
        </div>

        <div class="criteria-box">
          <div class="criteria-header">六 · 互联网原生性 <span class="dim-light">0–10</span></div>
          <p class="criteria-intro">这个人的名气和现象靠互联网到什么程度。</p>
          <div class="score-row"><span class="sr-label">0–2</span><div class="sr-bar"><div class="sr-fill" style="width:15%"></div></div></div>
          <div class="score-row"><span class="sr-label">3–5</span><div class="sr-bar"><div class="sr-fill" style="width:35%"></div></div></div>
          <div class="score-row"><span class="sr-label">6–8</span><div class="sr-bar"><div class="sr-fill" style="width:55%"></div></div></div>
          <div class="score-row"><span class="sr-label">9–10</span><div class="sr-bar"><div class="sr-fill high" style="width:75%"></div></div></div>
          <div class="score-notes">丁真 9（7 秒撑起全部）· 吴京 1</div>
        </div>
      </div>

      <!-- 叁 -->
      <div class="section">
        <div class="s-h"><span class="num">叁</span>否决条件</div>
        <p>具备以下任意一项，即使六维评分达标也不收录：</p>
        <div class="criteria-grid">
          <div class="criteria-item"><div class="ci-name" style="color:#7a5a4a">纯营销产物</div><div class="ci-desc">MCN 按公式批量生产的达人，缺乏不可复制性</div></div>
          <div class="criteria-item"><div class="ci-name" style="color:#7a5a4a">纯猎奇消费</div><div class="ci-desc">单纯消费身体缺陷或苦难，不承载文化意义</div></div>
          <div class="criteria-item"><div class="ci-name" style="color:#7a5a4a">信息不确</div><div class="ci-desc">核心事实模糊，无法构建可信叙事</div></div>
          <div class="criteria-item"><div class="ci-name" style="color:#7a5a4a">运营者本人</div><div class="ci-desc">不收录自己人</div></div>
        </div>
      </div>

      <!-- 肆 -->
      <div class="section">
        <div class="s-h"><span class="num">肆</span>收录流程</div>
        <div style="display:flex;gap:4px;margin:16px 0;flex-wrap:wrap">
          <div style="flex:1;min-width:120px;background:rgba(18,15,13,0.3);border:1px solid rgba(60,45,35,0.25);padding:14px 12px;text-align:center">
            <div style="font-size:20px;color:var(--c-text-faintest);font-family:Georgia,serif">①</div>
            <div style="font-size:10px;color:var(--c-text-faint-light);letter-spacing:3px">提名</div>
            <div style="font-size:8px;color:var(--c-text-faintest);letter-spacing:2px;margin-top:4px">请愿墙 / 发现</div>
          </div>
          <div style="flex:1;min-width:120px;background:rgba(18,15,13,0.3);border:1px solid rgba(60,45,35,0.25);padding:14px 12px;text-align:center">
            <div style="font-size:20px;color:var(--c-text-faintest);font-family:Georgia,serif">②</div>
            <div style="font-size:10px;color:var(--c-text-faint-light);letter-spacing:3px">初审</div>
            <div style="font-size:8px;color:var(--c-text-faintest);letter-spacing:2px;margin-top:4px">六维评分 ≥36</div>
          </div>
          <div style="flex:1;min-width:120px;background:rgba(18,15,13,0.3);border:1px solid rgba(60,45,35,0.25);padding:14px 12px;text-align:center">
            <div style="font-size:20px;color:var(--c-text-faintest);font-family:Georgia,serif">③</div>
            <div style="font-size:10px;color:var(--c-text-faint-light);letter-spacing:3px">归档</div>
            <div style="font-size:8px;color:var(--c-text-faintest);letter-spacing:2px;margin-top:4px">事实核查 + 写作</div>
          </div>
          <div style="flex:1;min-width:120px;background:rgba(18,15,13,0.3);border:1px solid rgba(60,45,35,0.25);padding:14px 12px;text-align:center">
            <div style="font-size:20px;color:var(--c-text-faintest);font-family:Georgia,serif">④</div>
            <div style="font-size:10px;color:var(--c-text-faint-light);letter-spacing:3px">入库</div>
            <div style="font-size:8px;color:var(--c-text-faintest);letter-spacing:2px;margin-top:4px">上线档案馆</div>
          </div>
        </div>
      </div>

      <!-- 伍 -->
      <div class="section">
        <div class="s-h"><span class="num">伍</span>现有馆藏评分</div>
        <div style="overflow-x:auto">
        <table class="score-table">
          <thead><tr>
            <th style="text-align:left;padding-left:12px">人物</th><th>国民度</th><th>争议性</th><th>荒诞性</th><th>时代切片</th><th>叙事弧光</th><th>互联网原生</th><th>总分</th>
          </tr></thead>
          <tbody>
            {sortedEntries.map(entry => (
              <tr>
                <td>{entry.title}</td>
                <td>{entry.scores.popularity}</td>
                <td>{entry.scores.dispute}</td>
                <td>{entry.scores.absurdity}</td>
                <td>{entry.scores.slice}</td>
                <td>{entry.scores.narrative}</td>
                <td>{entry.scores.native}</td>
                <td>{entry.total}</td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
        <p style="font-size:10px;color:var(--c-text-faintest);letter-spacing:2px;margin-top:8px">吴京 37 分，战狼文化符号加持下的国民度达到了准入标准。</p>
      </div>

      <!-- 陆 -->
      <div class="section">
        <div class="s-h"><span class="num">陆</span>终审原则</div>
        <div class="quote-block" style="border-left-color:rgba(80,65,50,0.6);background:rgba(22,18,14,0.4)">
          <em>❝</em>
          <p style="text-indent:0;font-size:13px;color:#b8a890;letter-spacing:3px;line-height:2">
            如果这个人不存在，<br />
            互联网的这段历史是不是就少了点什么？
          </p>
          <div style="margin-top:12px;font-size:10px;color:var(--c-text-faintest);letter-spacing:4px;line-height:2">
            <span style="color:var(--c-text-faint-light)">合格</span> 少了点精彩。<br />
            <span style="color:var(--c-text-faint-light)">优秀</span> 少了块拼图。<br />
            <span class="dim">不入</span> 少了谁都一样。
          </div>
        </div>
      </div>

      <!-- 柒 -->
      <div class="section">
        <div class="s-h"><span class="num">柒</span>奇观自测评分实验室</div>
        <p class="no-indent">你认为哪位互联网人物也能成为“奇观标本”？在下方拉动滑块进行模拟评分（总分达 36 分即可建议立项）：</p>
        
        <div class="lab-grid">
          <div class="lab-sliders">
            <div class="lab-slider-row">
              <span class="lab-label">一 · 国民度 (0-10): <b id="lab-val-popularity">5</b></span>
              <input type="range" class="lab-slider" id="lab-slide-popularity" min="0" max="10" value="5" />
            </div>
            <div class="lab-slider-row">
              <span class="lab-label">二 · 争议性 (0-10): <b id="lab-val-dispute">5</b></span>
              <input type="range" class="lab-slider" id="lab-slide-dispute" min="0" max="10" value="5" />
            </div>
            <div class="lab-slider-row">
              <span class="lab-label">三 · 荒诞性 (0-10): <b id="lab-val-absurdity">5</b></span>
              <input type="range" class="lab-slider" id="lab-slide-absurdity" min="0" max="10" value="5" />
            </div>
            <div class="lab-slider-row">
              <span class="lab-label">四 · 时代切片性 (0-10): <b id="lab-val-slice">5</b></span>
              <input type="range" class="lab-slider" id="lab-slide-slice" min="0" max="10" value="5" />
            </div>
            <div class="lab-slider-row">
              <span class="lab-label">五 · 叙事弧光 (0-10): <b id="lab-val-narrative">5</b></span>
              <input type="range" class="lab-slider" id="lab-slide-narrative" min="0" max="10" value="5" />
            </div>
            <div class="lab-slider-row">
              <span class="lab-label">六 · 互联网原生性 (0-10): <b id="lab-val-native">5</b></span>
              <input type="range" class="lab-slider" id="lab-slide-native" min="0" max="10" value="5" />
            </div>
          </div>
          
          <div class="lab-viz">
            <div class="lab-radar-box">
              <svg id="lab-radar" width="160" height="160" viewBox="0 0 160 160" style="overflow:visible">
                <!-- 动态变化雷达图 -->
              </svg>
            </div>
            <div class="lab-result">
              <div class="lab-score-title">自测总评分</div>
              <div class="lab-score-num" id="lab-total-score">30</div>
              <div class="lab-status-badge" id="lab-status">评估中</div>
            </div>
          </div>
        </div>
      </div>

      <div style="text-align:center;margin-top:24px">
        <a class="back-link" href="/">返回档案馆</a>
      </div>
    </div>
    <div class="footer">
      <span style="opacity:.4">🦞 麻辣小龙虾 · 标准随时修订</span>
    </div>
  </div>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const labRadar = document.getElementById('lab-radar');
      if (!labRadar) return;

      const sliders = ['popularity', 'dispute', 'absurdity', 'slice', 'narrative', 'native'];
      const values = { popularity: 5, dispute: 5, absurdity: 5, slice: 5, narrative: 5, native: 5 };
      const center = 80; // 雷达中心位置 (160x160 canvas 的 80)
      const maxRadius = 55;
      const angleStep = Math.PI / 3;

      function createSVGEl(type, attrs = {}) {
        const el = document.createElementNS('http://www.w3.org/2000/svg', type);
        for (const [key, val] of Object.entries(attrs)) {
          el.setAttribute(key, val);
        }
        return el;
      }

      // 绘制 5 层同心六边形网格
      for (let level = 1; level <= 5; level++) {
        const radius = (level / 5) * maxRadius;
        const points = [];
        for (let i = 0; i < 6; i++) {
          const angle = i * angleStep - Math.PI / 2;
          const x = center + radius * Math.cos(angle);
          const y = center + radius * Math.sin(angle);
          points.push(`${x},${y}`);
        }
        labRadar.appendChild(createSVGEl('polygon', {
          class: 'lab-grid',
          points: points.join(' ')
        }));
      }

      // 绘制 6 条轴线
      for (let i = 0; i < 6; i++) {
        const angle = i * angleStep - Math.PI / 2;
        const axisX = center + maxRadius * Math.cos(angle);
        const axisY = center + maxRadius * Math.sin(angle);
        labRadar.appendChild(createSVGEl('line', {
          class: 'lab-axis',
          x1: center,
          y1: center,
          x2: axisX,
          y2: axisY
        }));
      }

      // 绘制多边形
      const poly = createSVGEl('polygon', {
        class: 'lab-poly',
        points: ''
      });
      labRadar.appendChild(poly);

      // 绘制圆点
      const dots = [];
      for (let i = 0; i < 6; i++) {
        const dot = createSVGEl('circle', {
          class: 'lab-dot',
          cx: center,
          cy: center,
          r: 2.5
        });
        labRadar.appendChild(dot);
        dots.push(dot);
      }

      // 更新自测雷达与总分状态
      function updateLab() {
        let total = 0;
        const currentPoints = [];
        
        sliders.forEach((s, i) => {
          const val = values[s];
          total += val;
          
          const angle = i * angleStep - Math.PI / 2;
          const radius = (val / 10) * maxRadius;
          const x = center + radius * Math.cos(angle);
          const y = center + radius * Math.sin(angle);
          
          currentPoints.push(`${x},${y}`);
          dots[i].setAttribute('cx', x);
          dots[i].setAttribute('cy', y);
        });

        poly.setAttribute('points', currentPoints.join(' '));
        
        // 更新文字
        document.getElementById('lab-total-score').textContent = total;
        
        // 判断状态
        const statusBadge = document.getElementById('lab-status');
        if (total >= 36) {
          statusBadge.textContent = '准入收录';
          statusBadge.className = 'lab-status-badge pass';
        } else {
          statusBadge.textContent = '暂不归档';
          statusBadge.className = 'lab-status-badge fail';
        }
      }

      // 绑定滑块
      sliders.forEach(s => {
        const slider = document.getElementById('lab-slide-' + s);
        const valLabel = document.getElementById('lab-val-' + s);
        if (slider) {
          slider.addEventListener('input', (e) => {
            const val = parseInt(e.target.value);
            if (valLabel) valLabel.textContent = val;
            values[s] = val;
            updateLab();
          });
        }
      });

      // 初始化更新一次
      updateLab();

      // 1. 动态生成打字机定位角标
      document.querySelectorAll('.criteria-box').forEach(box => {
        ['tl', 'tr', 'bl', 'br'].forEach(pos => {
          const span = document.createElement('span');
          span.className = 'corner-mark ' + pos;
          span.textContent = '+';
          box.appendChild(span);
        });
      });

      // 2. 页面载入时播放纸张沙沙声
      try {
        if (window.__archiveAudio) {
          window.__archiveAudio.playPaperRustleSound();
        }
      } catch(e) {}

      // 3. 绑定返回链接点击音效
      document.querySelectorAll('.top-back a, .back-link').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const targetUrl = link.getAttribute('href');
          try {
            if (window.__archiveAudio) {
              window.__archiveAudio.playPaperRustleSound();
            }
          } catch(err) {}
          setTimeout(() => {
            window.location.href = targetUrl;
          }, 80);
        });
      });
    });
  </script>
</Layout>

<style>
  /* ── 自测实验室 ── */
  .lab-grid {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 30px;
