---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const rawEntries = await getCollection('phenomenon');
const slugs = rawEntries.map(item => item.id);
const slugNames = {};
rawEntries.forEach(item => {
  slugNames[item.id] = item.data.title;
});
---
<Layout title="机密档案后台 · 图片管理">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
  <div id="app"></div>
  <div id="toast" class="toast"></div>

  <!-- 大图预览 Modal -->
  <div id="preview-modal" class="modal" onclick="closePreview()">
    <span class="close-modal" onclick="closePreview()">&times;</span>
    <img class="modal-content" id="modal-img" onclick="event.stopPropagation()">
    <div id="modal-caption"></div>
    <div class="modal-actions" onclick="event.stopPropagation()">
      <button class="btn btn-primary" onclick="setAvatarFromPreview()">设为当前头像</button>
      <button class="btn" style="margin-left: 10px" onclick="closePreview()">关闭</button>
    </div>
  </div>

  <!-- 图片裁剪 Modal (3:4 证件照比例) -->
  <div id="crop-modal" class="modal" onclick="closeCropModal()">
    <div class="crop-modal-content" onclick="event.stopPropagation()">
      <div class="crop-title">📷 框选证件照显示区域</div>
      <div class="crop-container">
        <img id="crop-preview-img" src="" style="display: block; max-width: 100%; max-height: 100%;">
      </div>
      <div class="modal-actions" style="margin-top: 15px; margin-bottom: 5px; text-align: right;">
        <button class="btn" onclick="closeCropModal()">取消</button>
        <button class="btn btn-primary" style="margin-left: 10px;" onclick="confirmCrop()">确认并保存为证件照</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ slugs, slugNames }}>
    const API = '/api';
    let TOKEN = '';
    const SLUGS = slugs;
    const SLUG_NAMES = slugNames;
    let currentPreviewData = null; // { slug, url }

    // Tab 导航及 CMS 状态变量
    let ACTIVE_TAB = 'images';
    let CACHED_IMAGE_STATUS = null;
    let CURRENT_CMS_SLUG = '';
    let CURRENT_YAML_CONTENT = '';
    let CMS_PHENOMENA_LIST = [];
    let EDIT_MODE = 'form'; // 'form' 或 'yaml'

    function toast(msg){
      const t=document.getElementById('toast');
      t.textContent=msg;
      t.classList.add('show');
      setTimeout(()=>t.classList.remove('show'),3500);
    }
    
    function authHeaders(){
      return{'X-Admin-Token':TOKEN,'Content-Type':'application/json'};
    }

    async function api(path,opts={}){
      const r=await fetch(API+path,{...opts,headers:{...authHeaders(),...opts.headers}});
      const d=await r.json();
      if(!r.ok&&d.error) throw new Error(d.error);
      return d;
    }

    window.togglePasswordVisibility = function(e) {
      e.preventDefault();
      const input = document.getElementById('token-input');
      const btn = e.currentTarget;
      if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🔒';
      } else {
        input.type = 'password';
        btn.textContent = '👁';
      }
    };

    function showLogin(){
      document.getElementById('app').innerHTML=`
        <div class="login-container">
          <div class="corner-border top-left"></div>
          <div class="corner-border top-right"></div>
          <div class="corner-border bottom-left"></div>
          <div class="corner-border bottom-right"></div>
          <div class="seal-container">
            <div class="seal-outer">
              <div class="seal-inner">
                <svg viewBox="0 0 100 100" class="seal-svg">
                  <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="1" fill="none" stroke-dasharray="3 3"/>
                  <polygon points="50,15 80,75 20,75" stroke="currentColor" stroke-width="1.5" fill="none"/>
                  <circle cx="50" cy="52" r="10" stroke="currentColor" stroke-width="1.5" fill="none"/>
                  <path d="M 50,22 L 50,42 M 35,68 L 45,58 M 65,68 L 55,58" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="classified-tag">CLASSIFIED // TOP SECRET</div>
          <h1>机密档案库管理</h1>
          <div class="sub">INTRANET ARCHIVE KEY SYSTEM</div>
          <div class="input-wrapper">
            <span class="key-icon">🔐</span>
            <input type="password" id="token-input" placeholder="输入访问密钥 (Access Key)" autofocus autocomplete="off">
            <button class="toggle-pwd-btn" onclick="togglePasswordVisibility(event)">👁</button>
          </div>
          <button class="submit-btn" onclick="login()">
            <span class="btn-text">验 证 登 入</span>
            <span class="btn-scanner"></span>
          </button>
          <div id="login-error" class="error"></div>
          <div class="security-notice">
            WARNING: UNAUTHORIZED ACCESS IS STRICTLY PROHIBITED<br>
            SYSTEM ACCESS IS MONITORED AND LOGGED
          </div>
        </div>
      `;
      document.getElementById('token-input').addEventListener('keydown',e=>{if(e.key==='Enter')login()});
    }

    async function login(){
      const val = document.getElementById('token-input').value;
      if(!val) { toast('请输入密钥'); return; }
      TOKEN=val;
      try{
        const r=await fetch(API+'/admin/verify',{method:'POST',headers:{'X-Admin-Token':TOKEN}});
        const d=await r.json();
        if(!d.ok) throw new Error('fail');
        localStorage.setItem('admin_token',TOKEN);
        loadDashboard();
      }catch(e){
        document.getElementById('login-error').textContent='密钥错误或无法建立连接';
        TOKEN='';
        const card = document.querySelector('.login-container');
        if(card) {
          card.classList.add('shake');
          setTimeout(()=>card.classList.remove('shake'),500);
        }
      }
    }

    // 后台骨架加载
    async function loadDashboard() {
      const app = document.getElementById('app');
      app.innerHTML = `
        <div class="admin-layout">
          <div class="admin-header">
            <div class="header-zone">
              <h1>局域网机密档案库管理端</h1>
              <div class="sub">INTRANET CLASSIFIED ARCHIVE CONTROL CENTER</div>
            </div>
            
            <div class="header-actions">
              <button class="btn btn-primary btn-rebuild" onclick="rebuildAndReload()">重建站点</button>
              <button class="btn logout-btn" onclick="logout()">退出登录</button>
            </div>
          </div>

          <div class="admin-tabs">
            <button class="tab-btn active" id="tab-btn-images" onclick="switchTab('images')">🖼 图片档案管理</button>
            <button class="tab-btn" id="tab-btn-suggestions" onclick="switchTab('suggestions')">📋 请愿立项审核</button>
            <button class="tab-btn" id="tab-btn-cms" onclick="switchTab('cms')">📝 档案内容编辑器</button>
          </div>

          <div id="tab-content" class="tab-content-zone"></div>
        </div>
      `;

      await renderTabContent();
    }

    async function switchTab(tabId) {
      if (ACTIVE_TAB === tabId) return;
      ACTIVE_TAB = tabId;
      
      document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
      const activeBtn = document.getElementById('tab-btn-' + tabId);
      if (activeBtn) activeBtn.classList.add('active');

      await renderTabContent();
    }

    async function renderTabContent() {
      const zone = document.getElementById('tab-content');
      zone.innerHTML = '<div class="loading"><div class="spinner"></div><br>正在加载绝密数据...</div>';

      try {
        if (ACTIVE_TAB === 'images') {
          const data = await api('/admin/image-status');
          CACHED_IMAGE_STATUS = data.status;
          renderImagesTab(CACHED_IMAGE_STATUS);
        } else if (ACTIVE_TAB === 'suggestions') {
          await renderSuggestionsTab();
        } else if (ACTIVE_TAB === 'cms') {
          await renderCMSTab();
        }
      } catch (e) {
        zone.innerHTML = `<div class="loading" style="color:#cc664e">数据加载失败: ${e.message}</div>`;
      }
    }

    async function rebuildAndReload(){
      const btn=document.querySelector('.btn-rebuild');
      if(btn) {
        btn.disabled=true;
        btn.classList.add('btn-loading');
        btn.textContent = '编译重建中...';
      }
      toast('正在启动站点构建引擎，请稍候...');
      try{
        const d=await api('/admin/rebuild',{method:'POST'});
        toast(d.ok?'构建请求提交成功，正在后台渲染':'重建失败: '+JSON.stringify(d));
        if(d.ok) setTimeout(async () => {
          if (ACTIVE_TAB === 'images') {
            const data = await api('/admin/image-status');
            CACHED_IMAGE_STATUS = data.status;
            renderImagesTab(CACHED_IMAGE_STATUS);
          }
        }, 4000);
      }catch(e){toast('构建失败: '+e.message)}
      if(btn) {
        btn.disabled=false;
        btn.classList.remove('btn-loading');
        btn.textContent = '重建站点';
      }
    }

    // 1. 渲染图片管理标签页
    function renderImagesTab(status){
      const entries=SLUGS.map(slug=>{
        const st=status[slug]||{hasAvatar:false,avatarUrl:null,altCount:0,altUrls:[]};
        const name=SLUG_NAMES[slug];
        const currentUrl=(st.avatarUrl||'/images/placeholder-avatar.svg')+'?t='+Date.now();
        const cb='?t='+Date.now();
        const alts=(st.altUrls||[]).map(url=>url+cb);
        return {slug,name,currentUrl,alts,altCount:st.altCount||0};
      });

      let html=`<div class="tab-desc">拖拽图片至卡片内可直接上传备选图 · 鼠标悬停支持预览或更换展示头像</div>
                <div class="status-bar">
                  <span class="stat">馆藏：${entries.length} 卷独立档案</span>
                  <span class="stat">|</span>
                  <span class="stat">激活头像：${entries.filter(e=>e.currentUrl.includes('avatar.jpg')).length} / ${entries.length}</span>
                </div>`;

      for(const e of entries){
        const hasCurrent=e.currentUrl.includes('avatar.jpg');
        html+='<div class="entry" id="entry-'+e.slug+'" ondragover="onDragOver(event, this)" ondragleave="onDragLeave(event, this)" ondrop="onDrop(event, \''+e.slug+'\', this)"><div class="entry-header"><img src="'+e.currentUrl+'" onerror="this.src=\'/images/placeholder-avatar.svg\'"><div><div class="name">'+e.name+'</div><div class="slug">'+e.slug+' ('+e.alts.length+' 张有效备选)</div></div><span class="avatar-badge '+(hasCurrent?'verified':'missing')+'">'+(hasCurrent?'✓ 头像就绪':'○ 缺自定义头像')+'</span></div><div class="imgs"><div class="img-card active"><img src="'+e.currentUrl+'" onerror="this.src=\'/images/placeholder-avatar.svg\'"><div class="card-overlay"><span class="overlay-btn" title="预览大图" onclick="previewImage(\''+e.slug+'\',\''+e.currentUrl+'\')">🔍</span></div><div class="label">当前头像</div><div class="check">✓</div></div>';

        let idx = 0;
        for(const alt of e.alts){
          const match = alt.match(/-alt-(\d+)\./);
          const realIndex = match ? parseInt(match[1], 10) : idx;
          
          html+='<div class="img-card" id="card-'+e.slug+'-alt-'+realIndex+'"><div class="del-btn" onclick="event.stopPropagation();delImage(\''+e.slug+'\','+realIndex+')">×</div><img src="'+alt+'" loading="lazy"><div class="card-overlay"><span class="overlay-btn" title="设为当前头像" onclick="setAvatar(\''+e.slug+'\',\''+alt+'\')">✓</span><span class="overlay-btn" title="预览大图" onclick="previewImage(\''+e.slug+'\',\''+alt+'\')">🔍</span></div><div class="label">备选图</div></div>';
          idx++;
        }

        html+='</div><div class="action-row">';
        html+='<button class="btn btn-small" onclick="toggleUpload(\''+e.slug+'\')">📤 手动上传</button>';
        html+='<button class="btn btn-small btn-fetch" onclick="fetchMore(\''+e.slug+'\', this)">🔍 搜更多表情包</button>';
        html+='</div>';
        html+='<div class="upload-zone" id="upload-'+e.slug+'"><input type="file" id="file-'+e.slug+'" accept="image/*" multiple><br><button class="btn btn-small btn-primary" onclick="uploadFiles(\''+e.slug+'\')">确认上传</button></div>';
        html+='</div>';
      }
      document.getElementById('tab-content').innerHTML=html;
    }

    function toggleUpload(slug){
      const z=document.getElementById('upload-'+slug);
      z.classList.toggle('show');
    }

    // 拖拽上传支持
    window.onDragOver = function(e, el) {
      e.preventDefault();
      el.classList.add('drag-over');
    }

    window.onDragLeave = function(e, el) {
      e.preventDefault();
      el.classList.remove('drag-over');
    }

    window.onDrop = async function(e, slug, el) {
      e.preventDefault();
      el.classList.remove('drag-over');
      const files = e.dataTransfer.files;
      if (!files.length) return;
      await doUpload(slug, files);
    }

    async function doUpload(slug, files) {
      let count=0;
      const total=files.length;
      toast('正在准备并传输 ' + total + ' 张图片...');
      for(const file of files){
        if (!file.type.startsWith('image/')) {
          toast('跳过非图片文件: ' + file.name);
          continue;
        }
        try{
          const dataUrl=await new Promise((resolve,reject)=>{
            const r=new FileReader();
            r.onload=()=>resolve(r.result);
            r.onerror=reject;
            r.readAsDataURL(file);
          });
          await api('/admin/upload-image',{method:'POST',body:JSON.stringify({slug,image:dataUrl,type:'avatar-alt'})});
          count++;
        }catch(e){toast('上传失败: '+file.name+' - '+e.message)}
      }
      toast('上传完毕，成功保存: '+count+'/'+total+' 张备选图');
      await renderTabContent();
    }

    async function uploadFiles(slug){
      const input=document.getElementById('file-'+slug);
      if(!input.files.length){toast('请选择本地图片文件');return}
      await doUpload(slug, input.files);
      input.value='';
      const z=document.getElementById('upload-'+slug);
      if(z) z.classList.remove('show');
    }

    async function fetchMore(slug, btn){
      if(btn) {
        btn.disabled = true;
        btn.textContent = '🔍 正在搜索抓取...';
      }
      toast('开始联网抓取 '+SLUG_NAMES[slug]+' 的相关图片，请耐心等待数十秒...');
      try{
        const d=await api('/admin/fetch-images',{method:'POST',body:JSON.stringify({slug})});
        if(d.count>0) toast('联网抓取完毕！已成功存入 '+d.count+' 张高清备选图片 🦞');
        else toast('搜索引擎中未匹配到合适的新图片，建议手动上传');
        await renderTabContent();
      }catch(e){
        toast('搜索失败: '+e.message);
        if(btn) {
          btn.disabled = false;
          btn.textContent = '🔍 搜更多表情包';
        }
      }
    }

    let activeCropper = null;
    let currentCropCallback = null;

    window.openCropModal = function(imageSrc, aspectRatio, callback) {
      const modal = document.getElementById('crop-modal');
      const img = document.getElementById('crop-preview-img');
      img.src = imageSrc;
      modal.style.display = 'block';

      if (activeCropper) activeCropper.destroy();
      
      // 初始化 Cropper.js 实例，限制 aspectRatio 为 3 / 4，禁止拖出边界
      activeCropper = new Cropper(img, {
        aspectRatio: aspectRatio,
        viewMode: 1,
        dragMode: 'move',
        background: false,
        autoCropArea: 0.9,
      });

      currentCropCallback = callback;
    };

    window.closeCropModal = function() {
      const modal = document.getElementById('crop-modal');
      modal.style.display = 'none';
      if (activeCropper) {
        activeCropper.destroy();
        activeCropper = null;
      }
      currentCropCallback = null;
    };

    window.confirmCrop = async function() {
      if (!activeCropper || !currentCropCallback) return;

      // 证件照格式导出为 360x480 的高质量 JPEG
      const canvas = activeCropper.getCroppedCanvas({
        width: 360,
        height: 480,
        imageSmoothingEnabled: true,
        imageSmoothingQuality: 'high'
      });

      const croppedBase64 = canvas.toDataURL('image/jpeg', 0.88);
      await currentCropCallback(croppedBase64);
      closeCropModal();
    };

    async function setAvatar(slug,url){
      if(url.includes('placeholder')) return;
      toast('正在加载源图片进行框选裁剪...');
      try{
        const cleanUrl = url.split('?')[0]; // 去除时间戳
        const r=await fetch(cleanUrl);
        const blob=await r.blob();
        reader.onload=function(){
          // 弹出 3:4 证件照裁剪 Modal
          openCropModal(reader.result, 3 / 4, async (croppedBase64) => {
            toast('正在保存证件照...');
            try{
              await api('/admin/upload-image',{method:'POST',body:JSON.stringify({slug,image:croppedBase64,type:'avatar'})});
              toast(SLUG_NAMES[slug]+' 的证件照头像已更新，正在重新生成前台主页...');
              // 自动触发重新构建，刷新预渲染的首页
              api('/admin/rebuild',{method:'POST'}).catch(()=>{});
              await renderTabContent();
            }catch(e){toast('更新失败: '+e.message)}
          });
        };
        reader.readAsDataURL(blob);
      }catch(e){toast('下载原图失败，可能由于跨域或临时失效: '+e.message)}
    }

    async function delImage(slug,idx){
      if(!confirm('确定永久删除该备选图片吗？删除后不可恢复。')) return;
      toast('正在删除备选图...');
      try{
        await api('/admin/delete-alt',{method:'POST',body:JSON.stringify({slug,index:idx})});
        toast('已删除');
        await renderTabContent();
      }catch(e){toast('删除失败: '+e.message)}
    }

    function previewImage(slug, url) {
      currentPreviewData = { slug, url };
      const modal = document.getElementById('preview-modal');
      const modalImg = document.getElementById('modal-img');
      const captionText = document.getElementById('modal-caption');
      
      modal.style.display = 'block';
      modalImg.src = url;
      captionText.textContent = '正在预览档案「' + SLUG_NAMES[slug] + '」的关联图片';
    }
    
    function closePreview() {
      document.getElementById('preview-modal').style.display = 'none';
      currentPreviewData = null;
    }
    
    // 2. 渲染请愿墙管理
    async function renderSuggestionsTab() {
      const data = await api('/admin/suggestions');
      const suggestions = data.suggestions || [];

      let html = `<div class="tab-desc">当前访客在首页提交的新档案请愿。可在此删除不合规内容，或对高热度条目一键立项。</div>`;

      if (suggestions.length === 0) {
        html += `<div class="empty-zone">📭 暂无待处理的访客请愿记录。</div>`;
        document.getElementById('tab-content').innerHTML = html;
        return;
      }

      html += `
        <div class="table-container">
          <table class="admin-table">
            <thead>
              <tr>
                <th>请愿人物名称</th>
                <th>提交时间</th>
                <th>管理操作</th>
              </tr>
            </thead>
            <tbody>
      `;

      for (const s of suggestions) {
        const timeStr = new Date(s.time).toLocaleString('zh-CN');
        const safeName = s.name.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
        
        html += `
          <tr>
            <td class="suggest-name-cell">${safeName}</td>
            <td class="time-cell">${timeStr}</td>
            <td class="action-cell">
              <button class="btn btn-small btn-primary" onclick="initiateCMSFromSuggest('${safeName}')">➕ 一键立项</button>
              <button class="btn btn-small btn-danger" onclick="deleteSuggest('${s.time}')">🗑 删除</button>
            </td>
          </tr>
        `;
      }

      html += `
            </tbody>
          </table>
        </div>
      `;

      document.getElementById('tab-content').innerHTML = html;
    }

    async function deleteSuggest(time) {
      if (!confirm('确定永久删除此条请愿吗？')) return;
      toast('正在删除请愿...');
      try {
        await api('/admin/suggestions', {
          method: 'POST',
          body: JSON.stringify({ time })
        });
        toast('请愿已删除');
        await renderSuggestionsTab();
      } catch (e) {
        toast('删除失败: ' + e.message);
      }
    }

    function initiateCMSFromSuggest(name) {
      switchTab('cms').then(() => {
        startNewPhenomenon(name);
      });
    }

    // 3. 渲染 CMS 档案编辑器
    async function renderCMSTab() {
      const data = await api('/admin/list-phenomena');
      CMS_PHENOMENA_LIST = data.list || [];

      let html = `
        <div class="cms-container">
          <div class="cms-sidebar">
            <button class="btn btn-primary btn-new-cms" onclick="startNewPhenomenon('')">➕ 新建独立档案</button>
            <div class="cms-list">
      `;

      for (const p of CMS_PHENOMENA_LIST) {
        const isActive = p.slug === CURRENT_CMS_SLUG ? 'active' : '';
        html += `
          <div class="cms-list-item ${isActive}" onclick="loadPhenomenon('${p.slug}')">
            <div class="item-title">${p.title}</div>
            <div class="item-slug">${p.slug}.yaml</div>
          </div>
        `;
      }

      html += `
            </div>
          </div>

          <div class="cms-workspace" id="cms-workspace">
            <div class="cms-welcome">
              <h3>📂 档案内容编辑器</h3>
              <p>请在左侧选择需要修改的人物档案，或者点击“新建独立档案”开始创建新档案。</p>
            </div>
          </div>
        </div>
      `;

      document.getElementById('tab-content').innerHTML = html;
      
      if (CURRENT_CMS_SLUG) {
        await loadPhenomenon(CURRENT_CMS_SLUG);
      }
    }

    async function loadPhenomenon(slug) {
      CURRENT_CMS_SLUG = slug;
      
      document.querySelectorAll('.cms-list-item').forEach(item => item.classList.remove('active'));
      const activeItem = Array.from(document.querySelectorAll('.cms-list-item'))
        .find(el => el.querySelector('.item-slug').textContent === slug + '.yaml');
      if (activeItem) activeItem.classList.add('active');

      const workspace = document.getElementById('cms-workspace');
      workspace.innerHTML = '<div class="loading"><div class="spinner"></div><br>正在读取档案配置文本...</div>';

      try {
        const data = await api('/admin/get-phenomenon?slug=' + slug);
        CURRENT_YAML_CONTENT = data.yamlContent;
        renderEditorWorkspace(slug, false);
      } catch (e) {
        workspace.innerHTML = `<div class="loading" style="color:#cc664e">读取档案失败: ${e.message}</div>`;
      }
    }

    function startNewPhenomenon(prefilledName = '') {
      CURRENT_CMS_SLUG = '';
      
      CURRENT_YAML_CONTENT = `title: "${prefilledName}"
english_name: ""
subtitle: ""
avatar: ""
hero_tag: ""
hero_type: ""
tags:
  - "${prefilledName}"
main_stat:
  big_number: ""
  big_unit: ""
  big_desc: ""
  big_sublabel: ""
  bio:
    - ""
home_metadata:
  tag: ""
  meta: ""
  stats:
    - val: ""
      label: ""
comment: ""
timeline:
  - text: ""
    year: ""
`;
      renderEditorWorkspace('', true);
    }

    function getYamlValue(yaml, key) {
      const regex = new RegExp(`^${key}:\\s*(['"]?)(.*?)\\1\\s*$`, 'm');
      const match = yaml.match(regex);
      return match ? match[2] : '';
    }

    function setYamlValue(yaml, key, value) {
      const regex = new RegExp(`^${key}:\\s*(['"]?).*?\\1\\s*$`, 'm');
      if (regex.test(yaml)) {
        return yaml.replace(regex, `${key}: "${value}"`);
      } else {
        return yaml + `\n${key}: "${value}"`;
      }
    }

    function renderEditorWorkspace(slug, isNew) {
      const workspace = document.getElementById('cms-workspace');
      
      const title = getYamlValue(CURRENT_YAML_CONTENT, 'title');
      const englishName = getYamlValue(CURRENT_YAML_CONTENT, 'english_name');
      const subtitle = getYamlValue(CURRENT_YAML_CONTENT, 'subtitle');
      const heroTag = getYamlValue(CURRENT_YAML_CONTENT, 'hero_tag');
      const heroType = getYamlValue(CURRENT_YAML_CONTENT, 'hero_type');
      
      const commentMatch = CURRENT_YAML_CONTENT.match(/^comment:\s*(?:>|\|)?\s*\n?([\s\S]*?)(?=\n\w+:|$)/m);
      let comment = commentMatch ? commentMatch[1].trim() : getYamlValue(CURRENT_YAML_CONTENT, 'comment');
      // 去除每一行可能的多余缩进，并将 <br> 转换回换行，利于表单展示
      comment = comment.replace(/^\s+/gm, '').replace(/<br\s*\/?>/gi, '\n');
      // 去除首尾的引号
      if (comment.startsWith('"') && comment.endsWith('"')) {
        comment = comment.slice(1, -1);
      } else if (comment.startsWith("'") && comment.endsWith("'")) {
        comment = comment.slice(1, -1);
      }

      const isFormActive = EDIT_MODE === 'form' ? 'active' : '';
      const isYamlActive = EDIT_MODE === 'yaml' ? 'active' : '';

      workspace.innerHTML = `
        <div class="editor-header">
          <div class="editor-title-zone">
            <h4>${isNew ? '✨ 新建独立档案' : '📝 编辑：' + title}</h4>
            <div class="editor-sub">${isNew ? '待指定 slug 文件名' : '文件路径：src/content/phenomenon/' + slug + '.yaml'}</div>
          </div>
          <div class="editor-mode-switch">
            <button class="mode-btn ${isFormActive}" onclick="switchEditorMode('form')">表单编辑</button>
            <button class="mode-btn ${isYamlActive}" onclick="switchEditorMode('yaml')">YAML 源码</button>
          </div>
        </div>

        <div class="editor-body">
          <div class="editor-pane" id="pane-form" style="display: ${EDIT_MODE === 'form' ? 'block' : 'none'}">
            <div class="form-grid">
              <div class="form-group">
                <label>档案英文标识 (Slug / 文件名) <span class="required">*</span></label>
                <input type="text" id="edit-slug" value="${slug}" ${isNew ? '' : 'disabled'} placeholder="例如: dingzhen, wujing">
                <div class="field-desc">仅支持英文字母、数字和下划线，作为文件名且不可更改。</div>
              </div>
              <div class="form-group">
                <label>奇观人物名称 (Title) <span class="required">*</span></label>
                <input type="text" id="edit-title" value="${title}" placeholder="例如: 丁真">
              </div>
              <div class="form-group">
                <label>英文别名 (English Name)</label>
                <input type="text" id="edit-english" value="${englishName}" placeholder="例如: Ding Zhen">
              </div>
              <div class="form-group">
                <label>副标题/勋章 (Subtitle)</label>
                <input type="text" id="edit-subtitle" value="${subtitle}" placeholder="例如: 丁真 · 理塘宣传大使 · 锐克五代">
              </div>
              <div class="form-group">
                <label>标志身份/外号 (Hero Tag)</label>
                <input type="text" id="edit-hero-tag" value="${heroTag}" placeholder="例如: 芝士雪豹 · 理塘第一帅">
              </div>
              <div class="form-group">
                <label>奇观定位 (Hero Type)</label>
                <input type="text" id="edit-hero-type" value="${heroType}" placeholder="例如: 纯真与流量的互联网图腾">
              </div>
            </div>
            
            <div class="form-group" style="margin-top: 16px;">
              <label>档案馆评语与生平事实 (Comment) <span class="required">*</span></label>
              <textarea id="edit-comment" rows="8" placeholder="填写人物的详细经历、成名梗的经过。支持使用换行。">${comment}</textarea>
            </div>
          </div>

          <div class="editor-pane" id="pane-yaml" style="display: ${EDIT_MODE === 'yaml' ? 'block' : 'none'}">
            <div class="yaml-editor-wrapper">
              <textarea id="edit-yaml" class="yaml-textarea" rows="18" autocomplete="off" spellcheck="false">${CURRENT_YAML_CONTENT}</textarea>
              <div class="field-desc">注意：请在此修改全部高级配置（如 timeline, ribbon 等）。请保持正确的缩进。</div>
            </div>
          </div>
        </div>

        <div class="editor-footer">
          <button class="btn btn-primary" onclick="saveCMSPhenomenon()">💾 保存档案</button>
        </div>
      `;
    }

    window.switchEditorMode = function(mode) {
      if (EDIT_MODE === mode) return;
      
      if (mode === 'yaml') {
        syncFormToYaml();
      } else {
        syncYamlToForm();
      }

      EDIT_MODE = mode;
      const isNew = !CURRENT_CMS_SLUG;
      renderEditorWorkspace(isNew ? '' : CURRENT_CMS_SLUG, isNew);
    };

    function syncFormToYaml() {
      const title = document.getElementById('edit-title').value.trim();
      const english = document.getElementById('edit-english').value.trim();
      const subtitle = document.getElementById('edit-subtitle').value.trim();
      const heroTag = document.getElementById('edit-hero-tag').value.trim();
      const heroType = document.getElementById('edit-hero-type').value.trim();
      const comment = document.getElementById('edit-comment').value;

      let yaml = CURRENT_YAML_CONTENT;
      yaml = setYamlValue(yaml, 'title', title);
      yaml = setYamlValue(yaml, 'english_name', english);
      yaml = setYamlValue(yaml, 'subtitle', subtitle);
      yaml = setYamlValue(yaml, 'hero_tag', heroTag);
      yaml = setYamlValue(yaml, 'hero_type', heroType);
      
      // 处理多行 comment 存入双引号转义的形式
      const commentRegex = /^comment:\s*(?:>|\|)?\s*\n?([\s\S]*?)(?=\n\w+:|$)/m;
      const safeComment = comment.replace(/\n/g, '<br>').replace(/"/g, '\\"');
      if (commentRegex.test(yaml)) {
        yaml = yaml.replace(commentRegex, `comment: "${safeComment}"`);
      } else {
        yaml += `\ncomment: "${safeComment}"`;
      }
      
      CURRENT_YAML_CONTENT = yaml;
    }

    function syncYamlToForm() {
      const yaml = document.getElementById('edit-yaml').value;
      CURRENT_YAML_CONTENT = yaml;
    }

    async function saveCMSPhenomenon() {
      if (EDIT_MODE === 'form') {
        syncFormToYaml();
      } else {
        syncYamlToForm();
      }

      const isNew = !CURRENT_CMS_SLUG;
      let slug = '';
      if (isNew) {
        slug = document.getElementById('edit-slug').value.trim();
      } else {
        slug = CURRENT_CMS_SLUG;
      }

      if (!slug) {
        toast('请输入 Slug 文件标识');
        return;
      }
      if (!/^[a-zA-Z0-9_-]+$/.test(slug)) {
        toast('Slug 仅支持英文字母、数字、短横线和下划线');
        return;
      }

      const title = getYamlValue(CURRENT_YAML_CONTENT, 'title') || slug;

      toast('正在保存档案...');
      try {
        await api('/admin/save-phenomenon', {
          method: 'POST',
          body: JSON.stringify({ slug, yamlContent: CURRENT_YAML_CONTENT })
        });
        
        toast(`档案「${title}」保存成功！请重新“重建站点”以刷新前台展示。`);
        CURRENT_CMS_SLUG = slug;
        
        await renderCMSTab();
      } catch (e) {
        toast('保存失败: ' + e.message);
      }
    }

    window.previewImage = previewImage;
    window.closePreview = closePreview;
    window.setAvatarFromPreview = async function() {
      if (!currentPreviewData) return;
      const { slug, url } = currentPreviewData;
      closePreview();
      await setAvatar(slug, url);
    };

    window.login = login;
    window.showLogin = showLogin;
    window.logout = logout;
    window.rebuildAndReload = rebuildAndReload;
    window.toggleUpload = toggleUpload;
    window.uploadFiles = uploadFiles;
    window.fetchMore = fetchMore;
    window.setAvatar = setAvatar;
    window.delImage = delImage;
    window.switchTab = switchTab;
    window.deleteSuggest = deleteSuggest;
    window.initiateCMSFromSuggest = initiateCMSFromSuggest;
    window.loadPhenomenon = loadPhenomenon;
    window.startNewPhenomenon = startNewPhenomenon;
    window.saveCMSPhenomenon = saveCMSPhenomenon;

    function logout(){localStorage.removeItem('admin_token');TOKEN='';showLogin()}

    // 自动载入与验证
    {
      const saved=localStorage.getItem('admin_token');
      if(saved){
        TOKEN=saved;
        fetch(API+'/admin/verify',{method:'POST',headers:{'X-Admin-Token':TOKEN}})
          .then(r=>r.json()).then(d=>{if(d.ok)loadDashboard();else showLogin()}).catch(()=>showLogin());
      }else showLogin();
    }
  </script>
</Layout>

