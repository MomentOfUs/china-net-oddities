---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700;900&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
  <style is:global>
    /* ═══════════════════════════════════════════════════════
       互联网奇观 · 人物档案馆 — 通用布局与背景层
       ═══════════════════════════════════════════════════════ */
    *{margin:0;padding:0;box-sizing:border-box}

    body{
      background:#0c0a09;
      font-family:'Noto Serif SC','ZCOOL XiaoWei','Source Han Serif SC','FangSong','STFangsong','STSong','Times New Roman',Georgia,serif;
      color:#d0c4b4;line-height:1.8;min-height:100vh;
      -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale
    }

    body::before{
      content:'';position:fixed;inset:0;pointer-events:none;z-index:9995;
      background:
        repeating-linear-gradient(87deg,transparent,transparent 40px,rgba(40,30,20,0.006) 40px,rgba(40,30,20,0.006) 41px),
        repeating-linear-gradient(3deg,transparent,transparent 50px,rgba(35,28,22,0.004) 50px,rgba(35,28,22,0.004) 51px);
      background-size:100% 100%
    }
    body::after{
      content:'';position:fixed;inset:0;pointer-events:none;z-index:9996;
      background:radial-gradient(ellipse 70% 60% at 50% 30%,rgba(197,168,128,0.015) 0%,transparent 60%),
        radial-gradient(ellipse 120% 100% at 50% 100%,rgba(0,0,0,0.55) 0%,transparent 60%);
    }
    body z{content:'';position:fixed;inset:0;pointer-events:none;z-index:9997;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 500 500' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='6' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.038'/%3E%3C/svg%3E");
      background-size:500px 500px;
    }

    /* ── 全局滚动条美化 ── */
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #0c0a09;
    }
    ::-webkit-scrollbar-thumb {
      background: rgba(197, 168, 128, 0.18);
      border-radius: 3px;
      transition: background 0.3s;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: rgba(197, 168, 128, 0.4);
    }
  </style>
</head>
<body>
  <z></z>
  <slot />
</body>
</html>
